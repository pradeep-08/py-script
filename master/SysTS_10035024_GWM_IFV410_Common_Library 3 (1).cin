//////////////////////////////////////////////////////////////


on timer Data_Sending1
{
int j;
int datalength;//JP
testwaitfortimeout(50);
datalength= l_temp1-5;//Jp FOR 64 BYTES DATA WRITE  UPDATE TO  10 TO SEND 9 cf
  write("data length = %d",datalength);
data_pack_cnt++;
  write("data_pack_cnt = %d",data_pack_cnt);
  if((length_cnt == 0x29 && datalength<=69) || (length_cnt == 0x26 && datalength<=48) || (length_cnt == 0x27 && datalength<=55))
  {
    l_temp1 = l_temp1+5;
    write("in IF Loop");
  }
if(data_pack_cnt <= (l_temp1-1) && length_cnt < 0x2F )
{
  write("In MAIN IF");
////////JP Added//////////////////////////
if(datalength<=13 && length_cnt==0x21)
{
DIAG_Req.dlc = datalength-5;
  write("In 21 IF");
}
else if(datalength<=20 && length_cnt==0x22)
{
DIAG_Req.dlc = datalength-12;
  write("In 22 IF");
}
else if(datalength<=27 && length_cnt==0x23)
{
DIAG_Req.dlc = datalength-19;
  write("In 23 IF");
}
else if(datalength<=34 && length_cnt==0x24)
{
DIAG_Req.dlc = datalength-26;
}
else if(datalength<=41 && length_cnt==0x25)
{
DIAG_Req.dlc = datalength-33;
}
else if(datalength<=48 && length_cnt==0x26)
{
DIAG_Req.dlc = datalength-40;
}
else if(datalength<=55 && length_cnt==0x27)
{
DIAG_Req.dlc = datalength-47;
}
else if(datalength<=62 && length_cnt==0x28)
{
DIAG_Req.dlc = datalength-54;
  write("In 28 IF");
}
else if(datalength<=69 && length_cnt==0x29)
{
DIAG_Req.dlc = datalength-61;
  write("In 29 IF");
}
/////////////////////////////////////////////
DIAG_Req.byte(0)= length_cnt;
for(j=1;j<=7;j++)
{
DIAG_Req.byte(j)= write_array_buff[data_pack_cnt] ;
data_pack_cnt++;
}
output(DIAG_Req);
length_cnt++;
//testStep("","Writeen %d bytes of data %d ",data_pack_cnt,(l_temp-1));
setTimer(Data_Sending1,50);
}}


