/** 
@brief EXPECTED_DATA

Function to add string to "expected_data" field.
String is added at the end of "expected_data" field

@param string input string
@param data input data
@param dspType input byte
@return  result(0)
@author BZA & PLE
*/

long EXPECTED_DATA (char string[], long data, byte dspType)
{
    long lResult;
    char strTemp[MAX_STR_LEN];
    char strBin[40];
    long lStrLen;
    
    if(wExpected_DataLen > 0)
    {
        if(dspType == _DEC)
        {
            lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s %d",string, data);
        }
        else if(_BIN == dspType)

        {

            _long_To_Bin_Str(data, strBin);

            lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s %s",string, strBin);

        }
        else
        {
            if(data < 0x10)
            {
                lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s 0x0%X",string, data);
            }
            else
            {
                lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s 0x%X",string, data);
            }
        }
        strncat(strExpected_Data, strTemp, MAX_STR_LEN);   
    }
    else
    {
        if(dspType == _DEC)
        {
            lStrLen = snprintf(strExpected_Data,MAX_STR_LEN,"%s %d",string, data);            
        }
        else if(_BIN == dspType)

        {

            _long_To_Bin_Str(data, strBin);

            lStrLen = snprintf(strAction,MAX_STR_LEN,"%s %s",string, strBin);

        }
        else
        {
            if(data < 0x10)
            {
                lStrLen = snprintf(strExpected_Data,MAX_STR_LEN,"%s 0x0%X",string, data);
            }
            else
            {
                lStrLen = snprintf(strExpected_Data,MAX_STR_LEN,"%s 0x%X",string, data);
            }
        }        
    }
   
    wExpected_DataLen = strlen(strExpected_Data); 

    Return lResult;
}

