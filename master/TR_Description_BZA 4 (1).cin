long EXPECTED_RANGE_DATA (char string[], int data1, int data2)
{
    long lResult;
    char strTemp[MAX_STR_LEN];
    long lStrLen;
    
    if(wExpected_DataLen > 0)
    {
        lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s 0x%X to 0x%X",string, data1, data2);
        strncat(strExpected_Data, strTemp, MAX_STR_LEN);  
    }
    else
    {
        lStrLen = snprintf(strExpected_Data,MAX_STR_LEN,"%s 0x%X to 0x%X",string, data1, data2);
    }
    
    wExpected_DataLen = strlen(strExpected_Data); 

    Return lResult;
}

/** 
@brief EXPECTED_DATA

Function to add string to "expected_data" field.
String is added at the end of "expected_data" field

@param string input string
@param msg_name is message name
@return  result(0)
@author BZA & PLE
*/

long EXPECTED_DATA (char string[], message* msg_name)
{
    long lResult;
    char strTemp[MAX_STR_LEN];
    char strByte[4];
    long lStrLen;
    byte i;
    
    strTemp[0]=0;
    if(wExpected_DataLen > 0)
    {
        lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s\\nID: %X, DLC: %d\\nData:",string, msg_name.ID & 0x7FFFFFFF, msg_name.DLC);
        //strncat(strExpected_Data, strTemp, MAX_STR_LEN);
    }
    else
    {
        lStrLen = snprintf(strExpected_Data,MAX_STR_LEN,"%s\\nID: %X, DLC: %d\\nData:",string, msg_name.ID & 0x7FFFFFFF, msg_name.DLC);
    }

    for(i=0; i<msg_name.DLC; i++)
    {
        if(msg_name.byte(i) < 0x10)
        {
            snprintf(strByte, 4, " 0%X", msg_name.byte(i));
        }
        else
        {
            snprintf(strByte, 4, " %X", msg_name.byte(i));
        }
        strncat(strTemp, strByte, MAX_STR_LEN);
    }

    strncat(strExpected_Data, strTemp, MAX_STR_LEN);   
    wExpected_DataLen = strlen(strExpected_Data); 

    Return lResult;
}

/** 
@brief ACTION_DATA

Function to add string to "action_data" field.
String is added at the end of "action_data" field

@param string input string
@param data input data
@param dspType input byte
@return  result(0)
@author BZA & PLE
*/

long ACTION_DATA (char string[], long data, byte dspType)
{
    long lResult;
    char strTemp[MAX_STR_LEN];
    char strBin[40];
    long lStrLen;
    
    if(wAction_DataLen > 0)
    {
        if(dspType == _DEC)
        {
            lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s %d",string, data);
        }
        else if(_BIN == dspType)

        {

            _long_To_Bin_Str(data, strBin);

            lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s %s",string, strBin);

        }
        else
        {
            if(data < 0x10)
            {
                lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s 0x0%X",string, data);
            }
            else
            {
                lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s 0x%X",string, data);
            }
        }
        strncat(strAction_Data, strTemp, MAX_STR_LEN);  
    }
    else
    {
        if(dspType == _DEC)
        {
            lStrLen = snprintf(strAction_Data,MAX_STR_LEN,"%s %d",string, data);
        }
        else if(_BIN == dspType)

        {

            _long_To_Bin_Str(data, strBin);

            lStrLen = snprintf(strAction,MAX_STR_LEN,"%s %s",string, strBin);

        }
        else
        {
            if(data < 0x10)
            {
                lStrLen = snprintf(strAction_Data,MAX_STR_LEN,"%s 0x0%X",string, data);
            }
            else
            {
                lStrLen = snprintf(strAction_Data,MAX_STR_LEN,"%s 0x%X",string, data);
            }
        }        
    }
   
    wAction_DataLen = strlen(strAction_Data); 

    Return lResult;
}

