/////////////////////////////////////////////////////////////////////



Read_DTC_06(long DTC) 
{ 
 // ACTION("Read DTC-19 06 "); 
  DIAG_Req.dlc = 8; 
  DIAG_Req.byte(0)=  0x06; 
  DIAG_Req.byte(1)=  0x19; 
  DIAG_Req.byte(2)=  0x06; 
  DIAG_Req.byte(3)=  (DTC & 0xFF0000) >> 16; 
  DIAG_Req.byte(4)=  (DTC & 0x00FF00) >> 8; 
  DIAG_Req.byte(5)=  DTC & 0x0000FF ; 
  DIAG_Req.byte(6)=  0xFF; 
  output(DIAG_Req); 
  testwaitfortimeout(200); 
  DIAGNOSTIC_REQUEST("",Tx_buffer,8); 
  OBSERVED_DATA("",O_Resp,16); 
  }


send_on_CAN_FUN (int d0,int d1,int d2,int d3,int d4,int d5,int d6,int d7)
{
          if((d0 < 0x10)||(d0==0x30))
          {
            FUN_Req.DLC = d0+1; //8
            req[0] = FUN_Req.BYTE(0) = d0;
            req[1] = FUN_Req.BYTE(1) = d1;
            req[2] = FUN_Req.BYTE(2) = d2; 
            req[3] = FUN_Req.BYTE(3) = d3;
            req[4] = FUN_Req.BYTE(4) = d4;
            req[5] = FUN_Req.BYTE(5) = d5;
            req[6] = FUN_Req.BYTE(6) = d6;
            req[7] = FUN_Req.BYTE(7) = d7;
                 // FUNC_REQUEST("",req,8);
            DIAGNOSTIC_REQUEST(" 0x10DBFEF1x   ",req,8);
            Output(FUN_Req);  
          }
          else if (d0 >= 0x10) 
          {
           // Count =  (DIAG_Req.BYTE(1))/8;
       //    Count =  d1/8;
           // for(i = 1; i <= Count; i++)
          //  {
                  FUN_Req.DLC = d0+1; 
