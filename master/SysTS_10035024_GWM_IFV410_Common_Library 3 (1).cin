Check(byte E_Resp_Start,byte E_Resp_End,byte O_Resp)
{ Step();
    if((O_Resp >= E_Resp_Start) && (O_Resp <= E_Resp_End))
    {
      count = 1;
    }
  
  if(count == 1)
  {
    Add_to_report(PASSED); 
    count=0;
  }
  else
  {
    Add_to_report(FAILED);  
    count=0;
  }
}

Clear_Buffer()
{ 
  write("clear");
  for(i=0;i<999;i++) 
  { 
  O_Resp[i] = 0; 
//    S_Req[i]=0;
    E_Resp[i]=0;
    W_array[i]=0;
  } 
//  for(i=0;i<20;i++) 
//  { 
//    S_Req[i]=0;
//  } 
} 

