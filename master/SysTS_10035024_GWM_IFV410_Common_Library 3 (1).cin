Read_DTC(int mask)
{
  Step();
  DIAG_Req.dlc = 8;
  DIAG_Req.byte(0)= 0x03;
  DIAG_Req.byte(1)= 0x19;
  DIAG_Req.byte(2)= 0x01;
  DIAG_Req.byte(3)= mask;
  DIAG_Req.byte(4)= 0x00;
  DIAG_Req.byte(5)= 0x00;
  DIAG_Req.byte(6)= 0x00;
  DIAG_Req.byte(7)= 0x00;
  output(DIAG_Req);
  
  DIAGNOSTIC_REQUEST("",Tx_buffer,8);
  testWaitForTimeout(100);
  
  if(O_Resp[0] < 0x10)
  {
  OBSERVED_DATA("",O_Resp,(O_Resp[0] +1 ));
  }
  if(O_Resp[0] == 0x10)
  {
  OBSERVED_DATA("",O_Resp ,( O_Resp[1] + ((O_Resp[1] - 6)/7) + ( (O_Resp[1]-6) % 7 ) + 2 ) );
  }
  
}
 

Read_DTC_Extended(long dtc_name_i)
{
  Step();
  ACTION("ReadDTCInformation Request Message");
  DIAG_Req.dlc = 8;
  DIAG_Req.byte(0)= 0x06;
  DIAG_Req.byte(1)= 0x19;
  DIAG_Req.byte(2)= 0x06;
  DIAG_Req.byte(3)= ( dtc_name_i >> 16 ) & 0xFF ;
  DIAG_Req.byte(4)= ( dtc_name_i >> 08 ) & 0xFF ;
  DIAG_Req.byte(5)= dtc_name_i & 0xFF ;
  DIAG_Req.byte(6)= 0xFF;
  DIAG_Req.byte(7)= 0x00;
  output(DIAG_Req);
  testWaitForTimeout(100);
  
  DIAGNOSTIC_REQUEST("",Tx_buffer,8);
  
  if(O_Resp[0] < 0x10)
  {
  OBSERVED_DATA("",O_Resp,(O_Resp[0] +1 ));
  }
  if(O_Resp[0] == 0x10)
  {
  OBSERVED_DATA("",O_Resp ,( O_Resp[1] + ((O_Resp[1] - 6)/7) + ( (O_Resp[1]-6) % 7 ) + 2 ) );
  }
  
  
}
  
Read_DTC_Extended_with_status(long dtc_name_i,byte expected)
{
  Step();
  ACTION("ReadDTCInformation Request Message");
  DIAG_Req.dlc = 8;
  DIAG_Req.byte(0)= 0x06;
  DIAG_Req.byte(1)= 0x19;
  DIAG_Req.byte(2)= 0x06;
  DIAG_Req.byte(3)= ( dtc_name_i >> 16 ) & 0xFF ;
  DIAG_Req.byte(4)= ( dtc_name_i >> 08 ) & 0xFF ;
  DIAG_Req.byte(5)= dtc_name_i & 0xFF ;
  DIAG_Req.byte(6)= 0xFF;
  DIAG_Req.byte(7)= 0x00;
  output(DIAG_Req);
  testWaitForTimeout(100);
  
  DIAGNOSTIC_REQUEST("",Tx_buffer,8);
  
  if(O_Resp[0] < 0x10)
  {
  OBSERVED_DATA("",O_Resp,(O_Resp[0] +1 ));
  }
  if(O_Resp[0] == 0x10)
  {
  OBSERVED_DATA("",O_Resp ,( O_Resp[1] + ((O_Resp[1] - 6)/7) + ( (O_Resp[1]-6) % 7 ) + 2 ) );
  }
  
  if(O_Resp[7] == expected)
    {
      {
      if((expected==0x89)||(expected==0x09)) 
        COMMENT_DATA("DTC is active");
      else if(expected==0x08)
        COMMENT_DATA("DTC is not active,it is in history");
       else
      COMMENT_DATA("No DTC is logged for DTC Number ");
    }
     Add_to_report(PASSED);
    }
    else
      Add_to_report(FAILED);
    
  
}


