    Expect5(0x24,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect6(0x25,0x40,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect7(0x26,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect8(0x27,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect9(0x28,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect10(0x29,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    EXPECTED_DATA("",E_Resp,80);
  
  return DTCStepCount;
}

int NRC_Check_TestCase(char TestcaseIDD[],int DTCStepCount,int DID_H,int DID_L)
{
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("NRC 13 for Less Number of Bytes in Message Length");
    STEP();
    send_on_CAN(0x02,0x22,DID_H,DID_L,0x00,0x00,0x00,0x00);
    testWaitForTimeout(500);
    OBSERVED_DATA("",O_Resp,8);
    Expect1(0x03,0x7F,0x22,0x13,0xCC,0xCC,0xCC,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp,8);
    Clear_Buffer();
  
  ////////////////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("NRC 13 for More Number of Bytes in Message Length");
    STEP();
    send_on_CAN(0x05,0x22,DID_H,DID_L,0x00,0x00,0x00,0x00);
    testWaitForTimeout(500);
    OBSERVED_DATA("",O_Resp,8);
    Expect1(0x03,0x7F,0x22,0x13,0xCC,0xCC,0xCC,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp,8);
    Clear_Buffer();
  
  return DTCStepCount;
}

int Default_Session_Functional_TestCase(char TestcaseIDD[],int DTCStepCount,int DID_H,int DID_L)
{
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("***Functional Addressing***");
    STEP();
    Add_To_Report(PASSED);
  
    //////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Enter Default Session");
    STEP();
    send_on_CAN_FUN(0x02,0x10,0x01,0x00,0x00,0x00,0x00,0x00);
    testWaitForTimeout(100);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x06,0x50,0x01,0x00,0x32,0x01,0xF4,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp);   
    Clear_Buffer();
  
    //////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Read DID in Default Session");
    STEP();
    send_on_CAN_FUN(0x03,0x22,DID_H,DID_L,0x00,0x00,0x00,0x00);
    testWaitForTimeout(100);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp); 
	  Clear_Buffer();
  
    ////////////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Write DID in Default Session");
    STEP();
    Write1(0x10,0x43,0x2E,DID_H,DID_L,0x01,0x01,0x01);
    Write2(0x21,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write3(0x22,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write4(0x23,0x01,0x01,0x01,0x01,0x01,0x01,0x01);  
    Write5(0x24,0x01,0x01,0x01,0x01,0x01,0x01,0x01);  
    Write6(0x25,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write7(0x26,0x01,0x01,0x01,0x01,0x01,0x01,0x01);  
    Write8(0x27,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write9(0x28,0x01,0x01,0x01,0x01,0x01,0x01,0x01);  
    Write10(0x29,0x01,0x01,0x01,0x01,0x01,0x01,0x01);  
    Write_did_FUN(DID_H,DID_L,0x50);
    testWaitForTimeout(100);
    DIAGNOSTIC_REQUEST("",Tx_buffer,80);
    testWaitForTimeout(200);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp,8);
    clear_buffer();
  
  return DTCStepCount;
}

int Extended_Session_Functional_TestCase(char TestcaseIDD[],int DTCStepCount,int DID_H,int DID_L)
{
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Enter Extended Session");
    STEP_DATA("Test Step");
    STEP();
    send_on_CAN_FUN(0x02,0x10,0x03,0x00,0x00,0x00,0x00,0x00);
    testWaitForTimeout(100);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x06,0x50,0x03,0x00,0x32,0x01,0xF4,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp);  
    Clear_Buffer();
    //////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Read DID in Extended Session - Without Security Access");
    STEP();
    send_on_CAN_FUN(0x03,0x22,DID_H,DID_L,0x00,0x00,0x00,0x00);
    testWaitForTimeout(500);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00); 
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp,8);
    //////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Write DID in Extended Session");
    STEP();
    Write1(0x10,0x43,0x2E,DID_H,DID_L,0x01,0x01,0x01);
    Write2(0x21,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write3(0x22,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write4(0x23,0x01,0x01,0x01,0x01,0x01,0x01,0x01);  
    Write5(0x24,0x01,0x01,0x01,0x01,0x01,0x01,0x01);  
    Write6(0x25,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write7(0x26,0x01,0x01,0x01,0x01,0x01,0x01,0x01);  
    Write8(0x27,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write9(0x28,0x01,0x01,0x01,0x01,0x01,0x01,0x01);  
    Write10(0x29,0x01,0x01,0x01,0x01,0x01,0x01,0x01);  
    Write_did_FUN(DID_H,DID_L,0x50);
    testWaitForTimeout(100);
    DIAGNOSTIC_REQUEST("",Tx_buffer,80);
