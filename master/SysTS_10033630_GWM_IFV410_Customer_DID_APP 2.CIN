void LRC_Calculation()
{   
   
    byte LRC = 0x00, LRC_HEX[2];
    int i;
    LRC = 0x00;
    for(i=5;i<=22;i++)
    {
      //if(i%8 != 0)           //To skip flow control bytes
      //{
        write("i = %d",i);
        LRC = LRC ^ O_Resp[i];
        write("LRC = %x",LRC);
      //}
    }
    
    LRC_HEX[0] = LRC & 0x0F;  //lower nibble
    LRC_HEX[1] = LRC & 0xF0;//higher nibble
    
    write("LRC_HEX[0] = %x",LRC_HEX[0]);
    write("LRC_HEX[1] = %x",LRC_HEX[1]);
    
    /************Byte2ASCIIHEX Conversion***********/
    if(LRC_HEX[0]==0x0A || LRC_HEX[0]==0x0B || LRC_HEX[0]==0x0C  || LRC_HEX[0]==0x0D || LRC_HEX[0]==0x0E || LRC_HEX[0]==0x0F)
    {
      write("in 1");
      LRC_HEX[0] = LRC_HEX[0] + 0x37;
    }
    else
   {
      LRC_HEX[0] = LRC_HEX[0] + 0x30;
    }
    
    if(LRC_HEX[1]==0xA0 || LRC_HEX[1]==0xB0 || LRC_HEX[1]==0xC0  || LRC_HEX[1]==0xD0 || LRC_HEX[1]==0xE0 || LRC_HEX[1]==0xF0)
    {
      write("in 1");
      LRC_HEX[1] = (LRC_HEX[1]/0x10) + 0x37;
    }
    else
    {
      LRC_HEX[1] = (LRC_HEX[1]/0x10) + 0x30;
    }
    write("LRC_HEX[0] = %x",LRC_HEX[0]);
    write("LRC_HEX[1] = %x",LRC_HEX[1]);
    OBSERVED_DATA("",O_Resp,32);
    
    Expect1(0x00,0x17,0x62,0xF1,0xC5,0x41,0x41,0x42);  //Byte 5,6 need to update
    Expect2(0x44,0x4E,0x42,0x31,0x41,0x30,0x30,0x30); 
    Expect3(0x31,0x30,0x31,0x30,0x30,0x30,0x30,LRC_HEX[1]);  
    Expect4(LRC_HEX[0],0xCC,0xCC,0xCC,0xCC,0xCC,0xCC,0xCC);  
    EXPECTED_DATA("",E_Resp,32);
    Check(E_Resp,O_Resp,32);
}

