Send_seed(int seed)
{

  DIAG_Req.dlc = 8;
  DIAG_Req.byte(0)= 0x04;
  DIAG_Req.byte(1)= 0x27;
  DIAG_Req.byte(2)= 0x02;
  
  Key_Mul=seed*20077;
  Key_Mul_Byte1=((((long)(Key_Mul))&0x0000ffff));
  Key_temp=(Key_Mul_Byte1+0x3039);
  Key_temp_xor=(Key_temp^0xA5A5);
  Key_Byte1=(((Key_temp_xor)& 0xff00)>>8);
  Key_Byte2=((Key_temp_xor)& 0x00ff);
  
  DIAG_Req.byte(3)= Key_Byte1 ;
  DIAG_Req.byte(4)= Key_Byte2 ;
  output(DIAG_Req);
}
   
   
       
