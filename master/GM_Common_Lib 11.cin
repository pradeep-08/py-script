/****************************************************************************************/
void Dis_Comm_phy()
{
    STEP();
    ACTION("Disable Communication"); //Disable Communication
    send_on_CAN(0x03,0x28,0x03,0x01,0x55,0x55,0x55,0x55);
    testWaitForTimeout(100);
    Expect(0x02,0x68,0x03,0xAA,0xAA,0xAA,0xAA,0xAA);
    OBSERVED_DATA("",O_Resp,8);
    EXPECTED_DATA("",E_Resp,8);
    
    Check(E_Resp,O_Resp);  
    Clear_Buffer();   
    
    
    testWaitForTimeout(1000);
}
