    Expect(0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00); 
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp);  
    Clear_Buffer();
    //////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Read DID in Test Session - Without Security Access");
    STEP();
    send_on_CAN_FUN(0x03,0x22,DID_H,DID_L,0x00,0x00,0x00,0x00);
    testWaitForTimeout(500);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00); 
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp,8);
    //////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Write DID in Test Session");
    STEP();
    Write1(0x10,0x43,0x2E,DID_H,DID_L,0x01,0x01,0x01);
    Write2(0x21,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write3(0x22,0x01,0x01,0x01,0x01,0x01,0x01,0x01);  
    Write_did_FUN(DID_H,DID_L,0x11);
    testWaitForTimeout(100);
    DIAGNOSTIC_REQUEST("",Tx_buffer,24);
    testWaitForTimeout(200);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp,8);
    clear_buffer();
    testWaitForTimeout(6000);
  return DTCStepCount;
 
}

int NegativeCase_Hard_Reset_Host_Checksum(char TestcaseIDD[],int DTCStepCount,int DID_H,int DID_L)
{
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Enter Default Session");
    STEP();
    send_on_CAN(0x02,0x10,0x01,0x00,0x00,0x00,0x00,0x00);
    testWaitForTimeout(100);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x06,0x50,0x01,0x00,0x32,0x01,0xF4,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp); 
    Clear_Buffer();
    
