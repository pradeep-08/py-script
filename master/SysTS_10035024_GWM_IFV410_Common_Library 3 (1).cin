Clear_DTC()
{
	DIAG_Req.dlc = 8;
  DIAG_Req.byte(0)= 0x04;
  DIAG_Req.byte(1)= 0x14;
  DIAG_Req.byte(2)= 0xFF;
  DIAG_Req.byte(3)= 0xFF;
  DIAG_Req.byte(4)= 0xFF;
  DIAG_Req.byte(5)= 0;
  DIAG_Req.byte(6)= 0;
  DIAG_Req.byte(7)= 0;
  output(DIAG_Req);
 
  ACTION("Clear DTCs");
  testWaitForTimeout(1000); 
  OBSERVED_DATA("",O_Resp,8);
  DIAGNOSTIC_REQUEST("",Tx_buffer,8);
  Expect(0x01,0x54,0x00,0x00,0x00,0x00,0x00,0x00);
  EXPECTED_DATA ("",E_Resp,8);  
  Check(E_Resp,O_Resp);
  testWaitForTimeout(2000);  
}

Clear_DTC_particular(long dtc_name_i)
{

	DIAG_Req.dlc = 8;
  DIAG_Req.byte(0)= 0x04;
  DIAG_Req.byte(1)= 0x14;
  DIAG_Req.byte(2)= ( dtc_name_i >> 16 ) & 0xFF ;
  DIAG_Req.byte(3)= ( dtc_name_i >> 08 ) & 0xFF ;
  DIAG_Req.byte(4)= dtc_name_i & 0xFF ;
  DIAG_Req.byte(5)= 0x00;
  DIAG_Req.byte(6)= 0x00;
  DIAG_Req.byte(7)= 0;
  
  
  
  output(DIAG_Req);
 
  ACTION("Clear Diagnostics ");
  testWaitForTimeout(1000); 
  OBSERVED_DATA("",O_Resp,8);
  DIAGNOSTIC_REQUEST("",Tx_buffer,8);
  Expect(0x01,0x54,0x00,0x00,0x00,0x00,0x00,0x00);
  EXPECTED_DATA ("",E_Resp,8);  
  Check(E_Resp,O_Resp);
  testWaitForTimeout(2000);  
}

RecycleIgnition(int y)
{
 Step();
	DIAG_Req.dlc = 8;
  DIAG_Req.byte(0)= 0x2;
  DIAG_Req.byte(1)= 0x11;
  DIAG_Req.byte(2)= y;
  DIAG_Req.byte(3)= 0x00;
  DIAG_Req.byte(4)= 0x00;
  DIAG_Req.byte(5)= 0x00;
  DIAG_Req.byte(6)= 0x00;
  DIAG_Req.byte(7)= 0x00;
  output(DIAG_Req);
  testwaitfortimeout(500);
  
  ACTION("Recycle Ignition "); 
  OBSERVED_DATA("",O_Resp,8);
  DIAGNOSTIC_REQUEST("",Tx_buffer,8);
  Expect(0x02,0x51,y,0xCC,0xCC,0xCC,0xCC,0xCC);
  EXPECTED_DATA ("",E_Resp,8);  
  Check(E_Resp,O_Resp);
  testWaitForTimeout(21000);  
}

Battery_Ignition()
{
  SetBattVoltage(0);
  testwaitfortimeout(2000);
  SetBattVoltage (12.5);
  testwaitfortimeout(3000);
}
