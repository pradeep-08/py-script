                testWaitForTimeout(50);
                Expect4(O_Resp[24],O_Resp[25],O_Resp[26],O_Resp[27],O_Resp[28],O_Resp[29],O_Resp[30],O_Resp[31]);
                testWaitForTimeout(50);
                Expect5(O_Resp[32],O_Resp[33],O_Resp[34],O_Resp[35],O_Resp[36],O_Resp[37],O_Resp[38],O_Resp[39]);
                testWaitForTimeout(50);
                EXPECTED_DATA("",E_Resp,40);
                OBSERVED_DATA("",O_Resp,40);
                      for(h=0; h<40; h++)
                          {
                             if(O_Resp[h]==0xFF)
                               {
                                 seeds++;
                               }    
                          }
                      if(seeds>=15)
                      {
                        AddToReport(PASSED);
                      }
                      else
                      {
                        AddToReport(FAILED);
                      }
                Clear_Buffer();
    testWaitForTimeout(5000);
                      
             
