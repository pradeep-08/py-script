{
    long lResult;
    char strTemp[MAX_STR_LEN];
    char strBin[40];
    long lStrLen;
    
    if(wExpectedLen > 0)
    {
        if(dspType == _DEC)
        {
            lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s %d",string, data);
        }
        else if(_BIN == dspType)

        {

            _long_To_Bin_Str(data, strBin);

            lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s %s",string, strBin);

        }
        else
        {
            if(data < 0x10)
            {
                lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s 0x0%X",string, data);
            }
            else
            {
                lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s 0x%X",string, data);
            }
        }
        strncat(strExpected, strTemp, MAX_STR_LEN);   
    }
    else
    {
        if(dspType == _DEC)
        {
            lStrLen = snprintf(strExpected,MAX_STR_LEN,"%s %d",string, data);
        }
        else if(_BIN == dspType)

        {

            _long_To_Bin_Str(data, strBin);

            lStrLen = snprintf(strAction,MAX_STR_LEN,"%s %s",string, strBin);

        }
        else
        {
            if(data < 0x10)
            {
                lStrLen = snprintf(strExpected,MAX_STR_LEN,"%s 0x0%X",string, data);
            }
            else
            {
                lStrLen = snprintf(strExpected,MAX_STR_LEN,"%s 0x%X",string, data);
            }
        }        
    }
   
    wExpectedLen = strlen(strExpected); 

    Return lResult;
}

