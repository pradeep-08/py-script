testcase TC26_PGS_153741()
  {
    /*-------------------------------Test Step 1--------------------------------------*/ 
    /*-----------------------------ACTION: set Battery voltage to 12v -----------------------------------*/
   
    Set_Bat_Vol(12);
    
    /*-------------------------------Test Step 2--------------------------------------*/ 
    /*-----------------------------ACTION: Read MEC -----------------------------------------*/   
    
    Read_MEC();
    
    /*-------------------------------Test Step 3--------------------------------------*/ 
    /*-----------------------------ACTION: Set powermode to OFF -----------------------------------------*/
    @IgnitionSwitch=0;
    Read_PowerMode();
    
    /*-------------------------------Test Step 4--------------------------------------*/ 
    /*-----------------------------ACTION: Enter Default Session ----------------------------------------*/
    Default_Session_Phy();
    
    /*-------------------------------Test Step 5--------------------------------------*/ 
    /*-----------------------------ACTION: Enter Extended Session ---------------------------------------*/
    Extended_Session_Phy();
    
    /*-------------------------------Test Step 6--------------------------------------*/ 
    /*-----------------------------ACTION: Activating Tester Present for every 2sec----------------------*/
   
    Tester_Present_Per_Start_Fun(2000);
    
    /*-------------------------------Test Step 7--------------------------------------*/ 
    /*-----------------------------ACTION: Disable DTC---------------------------------------------------*/
    Dis_DTC_Phy();
    
    /*-------------------------------Test Step 8--------------------------------------*/ 
    /*-----------------------------ACTION: Disable Communication----------------------*/
    
    Dis_Comm_phy();
    
    /*-------------------------------Test Step 9--------------------------------------*/ 
    /*-----------------------------ACTION: Security unlock Level 1----------------------------------------*/
    ACTION("Checking whether a valid Seed [non-zero, non-FF] for Security Level 1 is recieved or not");
    Security_Unlock_With_Key_lvl_1_Phy();
    
    testWaitForTimeout(4000);
    
    /*-------------------------------Test Step 10--------------------------------------*/ 
    /*-----------------------------ACTION: Write RID 21E ----------------------------------------*/
    Write_RID_21E();   //InitialRefalshFlag
    
    /*-------------------------------Test Step 11--------------------------------------*/ 
    /*-----------------------------ACTION: Enter Programming_Session-------------------------------------*/
     Programming_Session_Phy();
    
    /*-------------------------------Test Step 12--------------------------------------*/ 
    /*-----------------------------ACTION: Enter Default Session ----------------------------------------*/
    STEP();
    ACTION("Enter Default Session"); //Default Session in boot P2 and P2* timer will be different 
    send_on_CAN(0x02,0x10,0x01,0x55,0x55,0x55,0x55,0x55);
    testWaitForTimeout(100);
    Expect(0x06,0x50,0x01,0x00,0x64,0x0B,0xB8,0x55);
    EXPECTED_DATA("",E_Resp,8);
    OBSERVED_DATA("",O_Resp,8);
    Check(E_Resp,O_Resp);  
    Clear_Buffer();   
    
    
    testWaitForTimeout(1000);
    
    /*-------------------------------Test Step 13--------------------------------------*/ 
    /*-----------------------------ACTION: Enter Extended Session ---------------------------------------*/
    Extended_Session_Phy();
    
    /*-------------------------------Test Step 14--------------------------------------*/ 
    /*-----------------------------ACTION: Security unlock Level 11----------------------------------------*/
    
    STEP();
