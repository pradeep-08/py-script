byte wShowTestStepID;

const word wLengthOfOutputPart         = 255;
char strDataOutputPart[wLengthOfOutputPart];

const word wLengthOfOutput             =  4*MAX_STR_LEN;
char strDataOutput[wLengthOfOutput];

word wLengthOfTestCaseRequirementString;
char strTestCaseRequirementString[MAX_STR_LEN];


