Security_Access()
{
  Session(3);  
  
  Step();
  Action("Unlock the ECU");
  Add_To_Report();
  
	Request_Seed();
  testwaitfortimeout(250);
  
//  ACTION("2nd Level Security Acess");
//  testWaitForTimeout(300); 
  DIAGNOSTIC_REQUEST("",Tx_buffer,8);
  OBSERVED_DATA("",O_Resp,8);
  Expect(0x02,0x67,0x02,0x00,0x00,0x00,0x00,0x00);
  EXPECTED_DATA ("",E_Resp,8);   
  Check(E_Resp,O_Resp,3);
  testWaitForTimeout(200);
}

Security_Access_A_Sample()
{
  Session(3);  
  Action("Request SEED");
  send_on_CAN (0x02,0x27,0x01,0x00,0x00,0x00,0x00,0x00);
  testWaitForTimeout(200);
  OBSERVED_DATA("",O_Resp,8);
  Expect(0x06,0x67,0x01,O_Resp[3],O_Resp[4],O_Resp[5],O_Resp[6],0x00);
  EXPECTED_DATA("",E_Resp,8);
  check(E_Resp,O_Resp,8);
  
  ACTION("Send KEY"); 
  send_on_CAN (0x06,0x27,0x02,0x00,0x00,0x00,0x01,0x00); 
  testWaitForTimeout(200);
  Expect(0x02,0x67,0x02,0x00,0x00,0x00,0x00,0x00);
  OBSERVED_DATA("",O_Resp,8);
  EXPECTED_DATA("",E_Resp,8);
  check(E_Resp,O_Resp,8);
}

