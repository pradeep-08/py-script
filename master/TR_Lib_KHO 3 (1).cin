long _PASSED ()
{
    long lresult;
    char strteststepID[10];

    lresult = 0;
    
    lresult =  _AddTaggedToOutput (strTITLE_DATA, TAG_TITLE_DATA);
    lresult |=  _AddTaggedToOutput (strLinked_Work_Items_DATA, TAG_Linked_Work_Items_DATA);
    lresult |=  _AddTaggedToOutput (strDescription_DATA, TAG_Description_DATA);
    lresult |=  _AddTaggedToOutput (strTestcaseID_DATA, TAG_TestcaseID_DATA);
    lresult |=  _AddTaggedToOutput (strSTEP_DATA, TAG_STEP_DATA);
  
    lresult |=  _Add_Tagged_To_Output (strAction, TAG_ACTION);
    lresult |= _Add_Tagged_To_Output (strAction_Data, TAG_ACTION_DATA);
    lresult |= _Add_Tagged_To_Output (strRequest, TAG_REQUEST);
    lresult |= _Add_Tagged_To_Output (strDiag_Request, TAG_DIAG_REQUEST);
    lresult |= _Add_Tagged_To_Output (strExpected, TAG_EXPECTED);
    lresult |= _Add_Tagged_To_Output (strExpected_Data, TAG_EXPECTED_DATA);
    lresult |= _Add_Tagged_To_Output (strObserved, TAG_OBSERVED);
    lresult |= _Add_Tagged_To_Output (strObserved_Data, TAG_OBSERVED_DATA);
    lresult |= _Add_Tagged_To_Output (strComment, TAG_COMMENT);
    lresult |= _Add_Tagged_To_Output (/*comment_data*/"", TAG_COMMENT_DATA);
    lresult |= _Add_Tagged_To_Output (strRequirement, TAG_REQUIREMENT_DATA);
  
    if(!lresult)
    {
        if(wActionLen > 0 || wShowTestStepID)
        {
            snprintf(strteststepID, 10, "%d", wTestStepID);
            TestStepPass(strteststepID,strDataOutput);
        }
        else
        {
            TestStepPass("",strDataOutput);
        }
    }

    _Clear_All_Data_Strings ();

    return lresult;
}

