Request_Seed()
{
  Step();
  Action("Request SEED");
  send_on_CAN (0x02,0x27,0x01,0x00,0x00,0x00,0x00,0x00);
  testWaitForTimeout(200);
  OBSERVED_DATA("",O_Resp,8);
  Expect(0x04,0x67,0x01,O_Resp[3],O_Resp[4],0x00,0x00,0x00);
  EXPECTED_DATA("",E_Resp,8);
  check(E_Resp,O_Resp,8);
  key_val1=Calculate_KEY(O_Resp[3],O_Resp[4]);
  testWaitForTimeout(100);
  Send_Key(key_val1);
  
}

Request_Seed1()
{
  Step();
  Action("Request SEED");
  send_on_CAN (0x02,0x27,0x01,0x00,0x00,0x00,0x00,0x00);
  testWaitForTimeout(200);
  OBSERVED_DATA("",O_Resp,8);
  Expect(0x04,0x67,0x01,O_Resp[3],O_Resp[4],0x00,0x00,0x00);
  EXPECTED_DATA("",E_Resp,8);
  check(E_Resp,O_Resp,8);
  key_val1=Calculate_KEY(O_Resp[3],O_Resp[4]);
  testWaitForTimeout(100);
  Send_Key1(key_val1);
  
}
 
Send_Key(long Cal_Key)
{  
   
  byte key1,key2;
  key1= ((Cal_Key>>8) & 0x000000FF);
  key2= (Cal_Key&0x000000FF);
  Step();
  ACTION("Send KEY"); 
  send_on_CAN (0x04,0x27,0x02,key1,key2,0x00,0x00,0x00); 
  testWaitForTimeout(200);
  Expect(0x02,0x67,0x02,0x00,0x00,0x00,0x00,0x00);
  OBSERVED_DATA("",O_Resp,8);
  EXPECTED_DATA("",E_Resp,8);
  check(E_Resp,O_Resp,8);
}

Send_Key1(long Cal_Key)
{  
  
  byte key1,key2;
  key1= ((Cal_Key>>7) & 0x000000FF);
  key2= (Cal_Key&0x000000FF);
  Step();
  ACTION("Send KEY"); 
  send_on_CAN (0x04,0x27,0x02,key1,key2,0x00,0x00,0x00); 
  testWaitForTimeout(200);
  Expect(0x02,0x67,0x02,0x00,0x00,0x00,0x00,0x00);
  OBSERVED_DATA("",O_Resp,8);
  EXPECTED_DATA("",E_Resp,8);
  check(E_Resp,O_Resp,8);
}

long Calculate_KEY(byte seed1,byte seed2)
{
  long seed_val,key_val;
  
  seed_val = ((seed1<<8) + seed2) & 0x0000FFFF ;
  key_val = (((seed_val * 20077) + 12345) ^ 0xA5A5);
  
  return key_val; 
}




