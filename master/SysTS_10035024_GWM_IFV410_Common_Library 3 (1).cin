on timer FUN_Data_Sending1
{
int j;
int datalength;//JP
testwaitfortimeout(50);
datalength= l_temp1-5;//JP
data_pack_cnt++;
  if(length_cnt == 0x29)
  {
    l_temp1 = l_temp1+5;
  }
if(data_pack_cnt <= (l_temp1-1) && length_cnt < 0x2F )
{
////////JP Added//////////////////////////
if(datalength<=13 && length_cnt==0x21)
{
FUN_Req.dlc = datalength-5;
}
else if(datalength<=20 && length_cnt==0x22)
{
FUN_Req.dlc = datalength-12;
}
else if(datalength<=27 && length_cnt==0x23)
{
FUN_Req.dlc = datalength-19;
}
else if(datalength<=34 && length_cnt==0x24)
{
FUN_Req.dlc = datalength-26;
}
else if(datalength<=41 && length_cnt==0x25)
{
FUN_Req.dlc = datalength-33;
}
else if(datalength<=48 && length_cnt==0x26)
{
FUN_Req.dlc = datalength-40;
}
else if(datalength<=55 && length_cnt==0x27)
{
FUN_Req.dlc = datalength-47;
}
else if(datalength<=62 && length_cnt==0x28)
{
FUN_Req.dlc = datalength-54;
}
else if(datalength<=69 && length_cnt==0x29)
{
FUN_Req.dlc = datalength-61;
}
/////////////////////////////////////////////
FUN_Req.byte(0)= length_cnt;
for(j=1;j<=7;j++)
{
FUN_Req.byte(j)= write_array_buff[data_pack_cnt] ;
data_pack_cnt++;
}
output(FUN_Req);
length_cnt++;
//testStep("","Writeen %d bytes of data %d ",data_pack_cnt,(l_temp-1));
setTimer(Data_Sending1,50);
}
}

