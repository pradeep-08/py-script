IFV300_REQ_SEED_Clear()
{
  send_on_CAN (0x02,0x27,0x01,0x00,0x00,0x00,0x00,0x00);
  testWaitForTimeout(50);
  OBSERVED_DATA("",O_Resp,8);
  Expect(0x06,0x67,0x01,O_Resp[3],O_Resp[4],O_Resp[5],O_Resp[6],0xCC);
  EXPECTED_DATA("",E_Resp,8);
 // check(E_Resp,O_Resp,8);
  GWM_KEY_VAL = IFV300_Calculate_KEY(O_Resp[3],O_Resp[4],O_Resp[5],O_Resp[6]);
  testWaitForTimeout(100);
  
}

IFV300_SEND_KEY_Clear()
{  
  
  byte key1,key2,key3,key4;
  key1= ((GWM_KEY_VAL>>24) & 0x000000FF);
  key2= ((GWM_KEY_VAL>>16) & 0x000000FF);
  key3= ((GWM_KEY_VAL>>8) & 0x000000FF);
  key4= (GWM_KEY_VAL&0x000000FF);
  Step();
  //ACTION("Send KEY"); 
  send_on_CAN (0x06,0x27,0x02,key1,key2,key3,key4,0x00); 
  testWaitForTimeout(200);
  Expect(0x02,0x67,0x02,0xCC,0xCC,0xCC,0xCC,0xCC);
  OBSERVED_DATA("",O_Resp,8);
  EXPECTED_DATA("",E_Resp,8);
  //check(E_Resp,O_Resp,8);
  
}

send_on_CAN_no_strings(int d0,int d1,int d2,int d3,int d4,int d5,int d6,int d7)
{
  DIAG_Req.DLC = 8; 
  req[0] = DIAG_Req.BYTE(0) = d0;
  req[1] = DIAG_Req.BYTE(1) = d1;
  req[2] = DIAG_Req.BYTE(2) = d2; 
  req[3] = DIAG_Req.BYTE(3) = d3;
  req[4] = DIAG_Req.BYTE(4) = d4;
  req[5] = DIAG_Req.BYTE(5) = d5;
  req[6] = DIAG_Req.BYTE(6) = d6;
  req[7] = DIAG_Req.BYTE(7) = d7;
  //DIAGNOSTIC_REQUEST("",req,8);
  
  Output(DIAG_Req);  
}
IFV300_SEND_KEY_ACC()
{  
  
  byte key1,key2,key3,key4;
  key1= ((GWM_KEY_VAL>>24) & 0x000000FF);
  key2= ((GWM_KEY_VAL>>16) & 0x000000FF);
  key3= ((GWM_KEY_VAL>>8) & 0x000000FF);
  key4= (GWM_KEY_VAL&0x000000FF);
  Step();
  //ACTION("Send KEY"); 
  send_on_CAN_no_strings (0x06,0x27,0x02,key1,key2,key3,key4,0x00); 
  testWaitForTimeout(200);
}



