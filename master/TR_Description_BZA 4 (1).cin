/** 
@brief ACTION

Function to add string to "action" field.
String is added at the end of "action" field

@param string input string
@param msg_name is message name
@return  result(0)
@author BZA & PLE
*/

long ACTION (char string[], message* msg_name)
{
    long lResult;
    char strTemp[MAX_STR_LEN];
    char strByte[4];
    long lStrLen;
    byte i;
    
    strTemp[0]=0;
    if(wActionLen > 0)
    {
        lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s\\nID: %X, DLC: %d\\nData:",string, msg_name.ID & 0x7FFFFFFF, msg_name.DLC);
        //strncat(strAction, strTemp, MAX_STR_LEN);
    }
    else
    {
        lStrLen = snprintf(strAction,MAX_STR_LEN,"%s\\nID: %X, DLC: %d\\nData:",string, msg_name.ID & 0x7FFFFFFF, msg_name.DLC);
    }

    for(i=0; i<msg_name.DLC; i++)
    {
        if(msg_name.byte(i) < 0x10)
        {
            snprintf(strByte, 4, " 0%X", msg_name.byte(i));
        }
        else
        {
            snprintf(strByte, 4, " %X", msg_name.byte(i));
        }
        strncat(strTemp, strByte, MAX_STR_LEN);
    }   

    strncat(strAction, strTemp, MAX_STR_LEN);    
    wActionLen = strlen(strAction); 

    Return lResult;
}

