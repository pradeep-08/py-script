    Write2(0x21,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write3(0x22,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write4(0x23,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write5(0x24,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write_did(DID_H,DID_L,0x21);
    testWaitForTimeout(100);
    DIAGNOSTIC_REQUEST("",Tx_buffer,40);
    testWaitForTimeout(200);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x03,0x7F,0x2E,0x31,0xCC,0xCC,0xCC,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp,8);
    testWaitForTimeout(5000);
    clear_buffer();
  return DTCStepCount;
}

int Test_Session_Phy_TestCase_VFP_Checksum(char TestcaseIDD[],int DTCStepCount,int DID_H,int DID_L)
