Check(byte E_Resp,byte O_Resp)
{
    if(E_Resp == O_Resp)
    {
      count = count+1;
    }
  
  if(count == 1)
  {
    Add_to_report(PASSED); 
    count=0;
  }
  else
  {
    Add_to_report(FAILED);  
    count=0;
  }
}


