long _IncreaseTestStepNumber ()
{
    long lresult;

    wTestStepID++;

    return lresult;
}

long STEP ()
{
    
    long lresult;

    wShowTestStepID = FALSE; //0 - test step number apear only with new action
    _Increase_Test_Step_Number ();

    return lresult;
    
}

long STEP (byte wShowTestStepID_local)
{
    
    long lresult;

    if(wShowTestStepID_local & SHOW_TS_NUMBER)
    {
        wShowTestStepID = TRUE; //user choose whenever to show number of line
    }

    if(wShowTestStepID_local & DO_NOT_INC_TS_NUMBER)
    {
        
    }
    else
    {
        _Increase_Test_Step_Number ();
    }

    return lresult;
    
}

long _AddTaggedToOutput (char data[], char tag[])
{
    //Error Code
    //0 - no error
    //1 - output length is too big

    long lresult;
    char strTemp[wLengthOfOutput];

    lresult = 0;

    if(0 != strlen(data))
    {
        if(strlen(strDataOutput) + strlen(data) + strlen(tag) + strlen(tag) + 5 <= wLengthOfOutput)
        {
            snprintf(strTemp, wLengthOfOutput, "<%s>%s</%s>", tag, data, tag);
            strncat(strDataOutput, strTemp, wLengthOfOutput);
        }
        else
        {
            lresult = 1;
        }
    }

    return lresult;
}

long _ClearAllDataStrings ()
{
    long lresult;

    lresult = 0;
  
  
    strTITLE_DATA[0]=0;
    wTITLE_DATA = 0;
  
  
    strLinked_Work_Items_DATA[0]=0;
    wLinked_Work_Items_DATA = 0;
  
  
    strDescription_DATA[0]=0;
    wDescription_DATA = 0;
  
  
    strTestcaseID_DATA[0]=0;
    wTestcaseID_DATA = 0;
  
    strSTEP_DATA[0]=0;
    wSTEP_DATA = 0;
   
  
    strAction[0]=0;
    wActionLen = 0;

    strRequest[0]=0;
    wExpectedLen = 0;
  
    strExpected[0]=0;
    wExpectedLen = 0;

    strComment[0]=0;
    wCommentLen = 0;

    strObserved[0]=0;
    wObservedLen = 0;

    strAction_Data[0]=0;
    wAction_DataLen = 0;
  
    strDiag_Request[0]=0;
    wDiag_RequestLen = 0;

    strExpected_Data[0]=0;
    wExpected_DataLen = 0;

    strObserved_Data[0]=0;
    wObserved_DataLen = 0;

    strComment_Data[0]=0;
    wComment_DataLen = 0;
  
    strRequirement[0]=0; 
    wRequirement=0; 

    snprintf(strDataOutput,wLengthOfOutput,"");

    return lresult;
}

long AddToReport (byte bTestResult)
{
    long lresult;
    char strteststepID[10];

    lresult = 0;
    
    lresult =  _AddTaggedToOutput (strTITLE_DATA, TAG_TITLE_DATA);
    lresult |=  _AddTaggedToOutput (strLinked_Work_Items_DATA, TAG_Linked_Work_Items_DATA);
    lresult |=  _AddTaggedToOutput (strDescription_DATA, TAG_Description_DATA);
    lresult |=  _AddTaggedToOutput (strTestcaseID_DATA, TAG_TestcaseID_DATA);
  lresult |=  _AddTaggedToOutput (strSTEP_DATA, TAG_STEP_DATA);
  
    lresult |=  _Add_Tagged_To_Output (strAction, TAG_ACTION);
    lresult |= _Add_Tagged_To_Output (strAction_Data, TAG_ACTION_DATA);
    lresult |= _Add_Tagged_To_Output (strRequest, TAG_REQUEST);
    lresult |= _Add_Tagged_To_Output (strDiag_Request, TAG_DIAG_REQUEST);
    lresult |= _Add_Tagged_To_Output (strExpected, TAG_EXPECTED);
    lresult |= _Add_Tagged_To_Output (strExpected_Data, TAG_EXPECTED_DATA);
    lresult |= _Add_Tagged_To_Output (strObserved, TAG_OBSERVED);
    lresult |= _Add_Tagged_To_Output (strObserved_Data, TAG_OBSERVED_DATA);
    lresult |= _Add_Tagged_To_Output (strComment, TAG_COMMENT);
    lresult |= _Add_Tagged_To_Output (strComment_Data, TAG_COMMENT_DATA);
    lresult |= _Add_Tagged_To_Output (strRequirement, TAG_REQUIREMENT_DATA);
  
    if(!lresult)
    {

        if(wActionLen > 0 || wShowTestStepID)
        {
            snprintf(strteststepID, 10, "%d", wTestStepID);
        }
        else
        {
            snprintf(strteststepID, 10, "");
        }
        
        if((bTestResult & NO_TS_NUMBER) > 0)
        {
            snprintf(strteststepID, 10, "");
            bTestResult = bTestResult & (~NO_TS_NUMBER);
        }
            
        switch(bTestResult)
        {
            case PASSED:
                TestStepPass(strteststepID,strDataOutput);
            break;
            case FAILED:
                TestStepFail(strteststepID,strDataOutput);
            break;
            case WARNING:
                TestStepWarning(strteststepID,strDataOutput);
            break;
            case N_A:
                TestStep(strteststepID,strDataOutput);
            break;
            default:
                TestStep(strteststepID,strDataOutput);
            break;
        }
    }

    _Clear_All_Data_Strings ();

    return lresult;
}

long STEPNb (int iStepID)
{
    long lresult;

    wTestStepID = iStepID;

    return lresult;
}

/** 
@brief Add current data to report.

Every data used after last STEP function or Add_To_Report will be added to report without result. 

@param iLight Parameter for something
@param iMeasurement Parameter for something <b>else</b>
@return  long error indicator
@author KHO
*/

long Add_To_Report ()
{
    long lresult;
    char strteststepID[10];

    lresult = 0;
    
    lresult =  _AddTaggedToOutput (strTITLE_DATA, TAG_TITLE_DATA);
    lresult |=  _AddTaggedToOutput (strLinked_Work_Items_DATA, TAG_Linked_Work_Items_DATA);
    lresult |=  _AddTaggedToOutput (strDescription_DATA, TAG_Description_DATA);
    lresult |=  _AddTaggedToOutput (strTestcaseID_DATA, TAG_TestcaseID_DATA);
  lresult |=  _AddTaggedToOutput (strSTEP_DATA, TAG_STEP_DATA);
  
    lresult |=  _Add_Tagged_To_Output (strAction, TAG_ACTION);
    lresult |= _Add_Tagged_To_Output (strAction_Data, TAG_ACTION_DATA);
    lresult |= _Add_Tagged_To_Output (strRequest, TAG_REQUEST);
    lresult |= _Add_Tagged_To_Output (strDiag_Request, TAG_DIAG_REQUEST);
    lresult |= _Add_Tagged_To_Output (strExpected, TAG_EXPECTED);
    lresult |= _Add_Tagged_To_Output (strExpected_Data, TAG_EXPECTED_DATA);
    lresult |= _Add_Tagged_To_Output (strObserved, TAG_OBSERVED);
    lresult |= _Add_Tagged_To_Output (strObserved_Data, TAG_OBSERVED_DATA);
    lresult |= _Add_Tagged_To_Output (strComment, TAG_COMMENT);
    lresult |= _Add_Tagged_To_Output (strComment_Data, TAG_COMMENT_DATA);
    lresult |= _Add_Tagged_To_Output (strRequirement, TAG_REQUIREMENT_DATA);
  
    if(!lresult)
    {
        if(wActionLen > 0 || wShowTestStepID)
        {
            snprintf(strteststepID, 10, "%d", wTestStepID);
            TestStep(strteststepID,strDataOutput);
        }
        else
        {
            TestStep("",strDataOutput);
        }
    }

    _Clear_All_Data_Strings ();

    return lresult;
}

/** 
@brief Add current data to report with verdict.

Every data used after last STEP function or Add_To_Report will be added to report with selected result. 

@param bTestResult Parameter with result <b>PASSED</b>, <b>FAILED</b>, <b>WARNING</b>, <b>N_A</b> optional <b>|NO_TS_NUMBER</b>
@return  long error indicator
@author KHO
*/

long Add_To_Report (byte bTestResult)
{
    long lresult;
    char strteststepID[10];

    lresult = 0;
    
    lresult =  _AddTaggedToOutput (strTITLE_DATA, TAG_TITLE_DATA);
    lresult |=  _AddTaggedToOutput (strLinked_Work_Items_DATA, TAG_Linked_Work_Items_DATA);
    lresult |=  _AddTaggedToOutput (strDescription_DATA, TAG_Description_DATA);
    lresult |=  _AddTaggedToOutput (strTestcaseID_DATA, TAG_TestcaseID_DATA);
  lresult |=  _AddTaggedToOutput (strSTEP_DATA, TAG_STEP_DATA);
  
    lresult |=  _Add_Tagged_To_Output (strAction, TAG_ACTION);
    lresult |= _Add_Tagged_To_Output (strAction_Data, TAG_ACTION_DATA);
    lresult |= _Add_Tagged_To_Output (strRequest, TAG_REQUEST);
    lresult |= _Add_Tagged_To_Output (strDiag_Request, TAG_DIAG_REQUEST);
    lresult |= _Add_Tagged_To_Output (strExpected, TAG_EXPECTED);
    lresult |= _Add_Tagged_To_Output (strExpected_Data, TAG_EXPECTED_DATA);
    lresult |= _Add_Tagged_To_Output (strObserved, TAG_OBSERVED);
    lresult |= _Add_Tagged_To_Output (strObserved_Data, TAG_OBSERVED_DATA);
    lresult |= _Add_Tagged_To_Output (strComment, TAG_COMMENT);
    lresult |= _Add_Tagged_To_Output (strComment_Data, TAG_COMMENT_DATA);
    lresult |= _Add_Tagged_To_Output (strRequirement, TAG_REQUIREMENT_DATA);
  
    if(!lresult)
    {

        if(wActionLen > 0 || wShowTestStepID)
        {
            snprintf(strteststepID, 10, "%d", wTestStepID);
        }
        else
        {
            snprintf(strteststepID, 10, "");
        }
        
        if((bTestResult & NO_TS_NUMBER) > 0)
        {
            snprintf(strteststepID, 10, "");
            bTestResult = bTestResult & (~NO_TS_NUMBER);
        }

        if((bTestResult & INC_TS_NUMBER) > 0)
        {
            _Increase_Test_Step_Number();
            snprintf(strteststepID, 10, "%d", wTestStepID);
            bTestResult = bTestResult & (~INC_TS_NUMBER);
        }

            
        switch(bTestResult & 0x0F)
        {
            case PASSED:
                TestStepPass(strteststepID,strDataOutput);
            break;
            case FAILED:
                TestStepFail(strteststepID,strDataOutput);
            break;
            case WARNING:
                TestStepWarning(strteststepID,strDataOutput);
            break;
            case N_A:
                TestStep(strteststepID,strDataOutput);
            break;
            default:
                TestStep(strteststepID,strDataOutput);
            break;
        }
    }

    _Clear_All_Data_Strings ();

    return lresult;
}

/** 
@brief Steart test report.

This function generates header of test cese, add informiation on begining of every test case in test report.

@param sTCIdentifier[] Uniqe identificator of Test Case
@param sTitle[] Title of Test Case
@param sDescription[] Description of Test Case
@param sReq[] List of requirements followed by ","
@param sParams[] List of parameters to control priority etc.
@return  long error indicator
@author KHO
*/
long Init_Test_Case_Report (char sTCIdentifier[], char sTitle[], char sDescription[], char sReq[], char sParams[])
{
    long lresult;
    char strTemp[MAX_STR_LEN];
    long lStrLen;

    wTestStepID = 0;

    wShowTestStepID = FALSE;

    _Clear_All_Data_Strings();

    //TestCaseTitle("", sTitle);
    TestCaseDescription(sDescription);

    testReportAddMiscInfoBlock("TCID:");
    testReportAddMiscInfo("TCID", sTCIdentifier);

    //
    //
    if(wLengthOfTestCaseRequirementString > 0)
    {
        if(strLen(sReq) > 0)
            lStrLen = snprintf(strTemp,MAX_STR_LEN,"%s;%s",sReq,strTestCaseRequirementString);         
        else
            lStrLen = snprintf(strTemp,MAX_STR_LEN,"%s",strTestCaseRequirementString);
    }
    else
    {
        lStrLen = snprintf(strTemp,MAX_STR_LEN,"%s",sReq);
    } 
    //
    //
    wLengthOfTestCaseRequirementString = 0;
    strTestCaseRequirementString[0] = 0;

    testReportAddMiscInfoBlock("Requirements:");
    testReportAddMiscInfo("REQ", strTemp);

    testReportAddMiscInfoBlock("Parameters:");
    testReportAddMiscInfo("PARAMS", sParams);

    return lresult;
}

/** 
@brief Start of test step with specified number.

This function 

@param sTCIdentifier[] Uniqe identificator of Test Case
@param sTitle[] Title of Test Case
@param sDescription[] Description of Test Case
@param sReq[] List of requirements followed by ","
@param sParams[] List of parameters to control priority etc.
@return  long error indicator
@author KHO
*/
long STEP_Nb (int iStepID)
{
    long lresult;

    wTestStepID = iStepID;

    return lresult;
}

long _Add_Tagged_To_Output (char data[], char tag[])
{
    //Error Code
    //0 - no error
    //1 - output length is too big

    long lresult;
    char strTemp[wLengthOfOutput];

    lresult = 0;

    if(0 != strlen(data))
    {
        if(strlen(strDataOutput) + strlen(data) + strlen(tag) + strlen(tag) + 5 <= wLengthOfOutput)
        {
            snprintf(strTemp, wLengthOfOutput, "<%s>%s</%s>", tag, data, tag);
            strncat(strDataOutput, strTemp, wLengthOfOutput);
        }
        else
        {
            lresult = 1;
        }
    }

    return lresult;
}

