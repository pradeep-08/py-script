int NegativeCase_Hard_Reset_VFP_Checksum(char TestcaseIDD[],int DTCStepCount,int DID_H,int DID_L)
{
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Enter Extended Session");
    STEP();
    send_on_CAN(0x02,0x10,0x03,0x00,0x00,0x00,0x00,0x00);
    testWaitForTimeout(100);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x06,0x50,0x03,0x00,0x32,0x01,0xF4,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp); 
    Clear_Buffer();
    
    //////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Read DID in Extended Session with Default Value");
    STEP();
    send_on_CAN(0x03,0x22,DID_H,DID_L,0x00,0x00,0x00,0x00);
    testWaitForTimeout(500);
    OBSERVED_DATA("",O_Resp,40);
    Expect1(0x10,0x21,0x62,DID_H,DID_L,0x00,0x00,0x00);
    Expect2(0x21,0xFF,0xFF,0x00,0x00,0x00,0x00,0x00);
    Expect3(0x22,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect4(0x23,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect5(0x24,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    EXPECTED_DATA("",E_Resp,40);
    Check(E_Resp,O_Resp,40);
    Clear_Buffer();
  
    //////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Give Ignition Reset - Hard Reset");
    STEP();
    send_on_CAN(0x02,0x11,0x01,0x00,0x00,0x00,0x00,0x00);
    testWaitForTimeout(3000);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x02,0x51,0x01,0xCC,0xCC,0xCC,0xCC,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp);
    Clear_Buffer(); 
  
    ////////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Enter Extended Session");
    STEP();
    send_on_CAN(0x02,0x10,0x03,0x00,0x00,0x00,0x00,0x00);
    testWaitForTimeout(100);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x06,0x50,0x03,0x00,0x32,0x01,0xF4,0x00);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp); 
    Clear_Buffer();
  
    //////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Read DID and check if the value remains same after reset");
    STEP();
    send_on_CAN(0x03,0x22,DID_H,DID_L,0x00,0x00,0x00,0x00);
    testWaitForTimeout(500);
    OBSERVED_DATA("",O_Resp,40);
    Expect1(0x10,0x21,0x62,DID_H,DID_L,0x00,0x00,0x00);
    Expect2(0x21,0xFF,0xFF,0x00,0x00,0x00,0x00,0x00);
    Expect3(0x22,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect4(0x23,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect5(0x24,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    EXPECTED_DATA("",E_Resp,40);
    Check(E_Resp,O_Resp,40);
    Clear_Buffer();
  return DTCStepCount;
}

