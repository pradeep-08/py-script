Send_FC()
{

  DIAG_Req.dlc = 8;
  DIAG_Req.byte(0)= 0x30;
  DIAG_Req.byte(1)= 0x00;
  DIAG_Req.byte(2)= 0x00;
  DIAG_Req.byte(3)= 0x00;
  DIAG_Req.byte(4)= 0x00;
  DIAG_Req.byte(5)= 0x00;
  DIAG_Req.byte(6)= 0x00;
  DIAG_Req.byte(7)= 0x00;
  output(DIAG_Req);
  testwaitfortimeout(50); 
}

Routine_Start(long routine_no)
{ Step();
      DIAG_Req.dlc = 8;
      DIAG_Req.byte(0)= 0x04;
      DIAG_Req.byte(1)= 0x31;
      DIAG_Req.byte(2)= 0x01;
      DIAG_Req.byte(3)= routine_no >> 8 ;  
      DIAG_Req.byte(4)= routine_no & 0x00FF ; 
      output(DIAG_Req);
      testwaitfortimeout(50);
      
      
    ACTION("Start Routine ",routine_no);
    testWaitForTimeout(100); 
    OBSERVED_DATA("",O_Resp,8);
    DIAGNOSTIC_REQUEST("",Tx_buffer,8); 
    Expect(0x04,0x71,0x01,(routine_no >> 8),(routine_no & 0x00FF),0x00,0x00,0x00);
    EXPECTED_DATA ("",E_Resp,8);    
    Check(E_Resp,O_Resp);
    testWaitForTimeout(1000);
    
}

Routine_Result(long routine_no)
{
   Step();
send_on_can(0x02,0x11,0x01,0x00,0x00,0x00,0x00,0x00); 
testWaitForTimeout(1000);
Security_Access();
 
      DIAG_Req.dlc = 8;
      DIAG_Req.byte(0)= 0x04;
      DIAG_Req.byte(1)= 0x31;
      DIAG_Req.byte(2)= 0x03;
      DIAG_Req.byte(3)= routine_no >> 8 ;  
      DIAG_Req.byte(4)= routine_no & 0x00FF ;
      output(DIAG_Req);
      testwaitfortimeout(50);
      
      ACTION(" Routine Result ",routine_no);
      testWaitForTimeout(100); 
      OBSERVED_DATA("",O_Resp,8);
      DIAGNOSTIC_REQUEST("",Tx_buffer,8); 
      Expect(0x05,0x71,0x03,(routine_no >> 8),(routine_no & 0x00FF),O_Resp[5],0x00,0x00);
      EXPECTED_DATA ("",E_Resp,8);    
      Check(E_Resp,O_Resp);
      testWaitForTimeout(1000);      
}

Routine_Stop(long routine_no)
{

      //Security_Access();
      DIAG_Req.dlc = 8;
      DIAG_Req.byte(0)= 0x04;
      DIAG_Req.byte(1)= 0x31;
      DIAG_Req.byte(2)= 0x02;
      DIAG_Req.byte(3)= routine_no >> 8 ;  
      DIAG_Req.byte(4)= routine_no & 0x00FF ; 
      output(DIAG_Req);
      testwaitfortimeout(50);
      
      ACTION("Stop Routine ",routine_no);
      testWaitForTimeout(100); 
      OBSERVED_DATA("",O_Resp,8);
      DIAGNOSTIC_REQUEST("",Tx_buffer,8); 
      Expect(0x04,0x71,0x02,(routine_no >> 8),(routine_no & 0x00FF),0x00,0x00,0x00);
      EXPECTED_DATA ("",E_Resp,8);    
      Check(E_Resp,O_Resp);
      testWaitForTimeout(1000);
}


Read_DID(long did)
{ 
  Step();

  DIAG_Req.dlc = 8;
  DIAG_Req.byte(0)= 0x03;
  DIAG_Req.byte(1)= 0x22;
  DIAG_Req.byte(2)= ( did & 0xFF00)>>8 ;
  DIAG_Req.byte(3)=  did & 0x00FF ;
  output(DIAG_Req);
   testwaitfortimeout(400); 
  
  DIAGNOSTIC_REQUEST("",Tx_buffer,8);
  
    if(O_Resp[0]==0x10)
     OBSERVED_DATA("",O_Resp,( O_Resp[1] + ((O_Resp[1] - 6)/7) + 3 ));
    else
     OBSERVED_DATA("",O_Resp,8);
     
}

