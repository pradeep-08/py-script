Check(byte E_Resp[],byte O_Resp[])
{
  for(i=0;i<8;i++)
  {
    if(E_Resp[i] == O_Resp[i])
    {
      count = count+1;
    }
  }
  
  if(count == 8)
  {
    Add_to_report(PASSED); 
    count=0;
  }
  else
  {
    Add_to_report(FAILED);  
    count=0;
  }
}

Check(byte E_Resp[],byte O_Resp[],int len)
{ 
  int count=0;
  int i=0;
  for(i=0;i<len;i++)
  {
    if(E_Resp[i] == O_Resp[i])
    {
      count = count+1;
    }
  }
  
  if(count == len)
  {
    Add_to_report(PASSED); 
    count=0;
  }
  else
  {
    Add_to_report(FAILED);  
    count=0;
  }
}

