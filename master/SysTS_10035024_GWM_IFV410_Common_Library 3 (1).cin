on message CAN1.0x14DA59F1x
{

    //Clear O_resp Buffer on receiving new diagnostic response
    if( this.byte(0) <= 0x10 )
    {
    buf_index = 0;
    for (rbufind=0;rbufind<200;rbufind++  )      
    {
      O_Resp[ rbufind ] = 0 ;      
    }
    buf_index = 0;
    }
  
    
    //Clear TX Buffer on sending new diagnostic request
    if( (this.byte(0) <= 0x10) )
     {
          for (tbufind=0;tbufind<200;tbufind++  )      
          {
            Tx_buffer[ tbufind ] = 0 ;      
          }
          tbuf_index = 0;
     }
    
     

       for (tbufind=0;tbufind<8;tbufind++  )      
         {
            Tx_buffer[ tbuf_index ] = this.byte(tbufind);  
            write("","%X-%X",tbuf_index,Tx_buffer[ tbuf_index ]);
            tbuf_index++;
            
         }
      
    
        
}

on message CAN1.0x14DAF159x
{
        //Send Flow Control If response more than a frame
        if((this.byte(0)&0xF0) == 0x10 )
         {  
           Send_FC();     
         }


        
 //store all data
        if( (this.byte(3)== 0x78) && (this.byte(1) != 0x7F) && (this.byte(2) > 0x30))
        {
          for (rbufind=0;rbufind<64;rbufind++  )      
          {
            O_Resp[ buf_index ] = this.byte(rbufind);      
            buf_index++;
          }
        }
        
        if( (this.byte(3)== 0x78) && (this.byte(1) != 0x7F)&& (this.byte(2) < 0x30))
        {
          for (rbufind=0;rbufind<48;rbufind++  )      
          {
            O_Resp[ buf_index ] = this.byte(rbufind);      
            buf_index++;
          }
        }
        
        if( ((this.byte(1) != 0x7F)&& (this.byte(2) < 0x30)))
        {
          for (rbufind=0;rbufind<48;rbufind++  )      
          {
            O_Resp[ buf_index ] = this.byte(rbufind);      
            buf_index++;
          }
        }

        
        if( (this.byte(3)!= 0x78) && (this.byte(2) > 0x30))
        {
           for (rbufind=0;rbufind<64;rbufind++  )      
            {
              Rx_buffer[ buf_index ] = this.byte(rbufind);      
              buf_index++;
            }
        }
        
         if( (this.byte(1)!= 0x7F) && (this.byte(2) > 0x30))
        {
           for (rbufind=0;rbufind<120;rbufind++  )      
            {
              Rx_buffer[ buf_index ] = this.byte(rbufind);      
              buf_index++;
            }
        }
         
         //
 if((this.byte(0)<=0x10)&&(this.byte(1)!=0x7F))

  {

    Res_buf_index = 0;

    for (rbufind=0;rbufind<8;rbufind++)

    {

      O_Resp[ Res_buf_index ] = this.byte(rbufind);

      Res_buf_index++;

    }

  }

  else if((this.byte(0)>0x10)||(this.byte(1)==0x7F))  // changed line no 206 rbufind=1 to avoid consecutive frame

  {

    for (rbufind=0;rbufind<8;rbufind++)

    {

      O_Resp[ Res_buf_index ] = this.byte(rbufind);

      Res_buf_index++;

    }

  }
 
  if(this.byte(1)==0x7F)

  {

    Res_buf_index = 0;

    for (rbufind=0;rbufind<8;rbufind++)

    {

      O_Resp[ Res_buf_index ] = this.byte(rbufind);

      Res_buf_index++;

    }

    Res_buf_index = 0;

  }        
 
        
        if( (this.byte(3)!= 0x78) && (this.byte(2) < 0x30))
        {
           for (rbufind=0;rbufind<48;rbufind++  )      
            {
              O_Resp[ buf_index ] = this.byte(rbufind);      
              buf_index++;
            }
        } 
           
          
        
        
        //If Flow control as response clear O_resp buffer and set index to 0
        if( this.byte(0) == 0x30 )
        {
        buf_index = 0;
        for (rbufind=0;rbufind<200;rbufind++  )      
        {
          O_Resp[ buf_index ] = 0 ;      
          buf_index++;
        }
        buf_index = 0;
        }
    
        // Send Key on response to  seed 3 bytes 
         if(( this.byte(0) == 0x06) && ( this.byte(1) == 0x067) && ( this.byte(2) == 0x01) )
         {
          //seed = ( this.byte(3)) * 0x1000000 + ( this.byte(4)) * 0x10000 + ( this.byte(5)) * 0x100 + ( this.byte(4)) ;
           SaccSeed = (( this.byte(3)<<24) +( this.byte(4)<<16) +( this.byte(5)<<8) +  this.byte(6)) & 0xFFFFFFFF ;
           write("SaccSeed2 value %x",SaccSeed);
         }
         
}

on message CAN1.0x10dbfef1x
{

    //Clear O_resp Buffer on receiving new diagnostic response
    if( this.byte(0) <= 0x10 )
    {
    buf_index = 0;
    for (rbufind=0;rbufind<200;rbufind++  )      
    {
      O_Resp[ rbufind ] = 0 ;      
    }
    buf_index = 0;
    }
  
    
    //Clear TX Buffer on sending new diagnostic request
    if( (this.byte(0) <= 0x10) )
     {
          for (tbufind=0;tbufind<200;tbufind++  )      
          {
            Tx_buffer[ tbufind ] = 0 ;      
          }
          tbuf_index = 0;
     }
    
     
    //Store TX Buffer 
    for (tbufind=0;tbufind<8;tbufind++  )      
     {
        Tx_buffer[ tbuf_index ] = this.byte(tbufind);  
        //teststep("","%X-%X",tbuf_index,Tx_buffer[ tbuf_index ]);
        tbuf_index++;
        
     }
        
}

on message can2.0x2F0
{
    //Clear O_resp Buffer on receiving new diagnostic response
    buf_index = 0;
    for (rbufind=0;rbufind<200;rbufind++ )      
    {
      O_Resp[ rbufind ] = 0 ;      
    }
    buf_index = 0;

    
    //Clear TX Buffer on sending new diagnostic request
    for (tbufind=0;tbufind<200;tbufind++)      
    {
       Tx_buffer[ tbufind ] = 0 ;      
    }
    tbuf_index = 0;

    //Store TX Buffer 
    for (tbufind=0;tbufind<8;tbufind++  )      
    {
      Tx_buffer[ tbuf_index ] = this.byte(tbufind);  
      //teststep("","%X-%X",tbuf_index,Tx_buffer[ tbuf_index ]);
      tbuf_index++;
    }
  
}

on message can2.0x2F1
{     
  buf_index = 0;
      //store all data
      for (rbufind=0;rbufind<8;rbufind++  )      
      {
         O_Resp[ buf_index ] = this.byte(rbufind);      
         buf_index++;
      }
//       buf_index = 0;
}

Send_on_CAN_XCP(int d0,int d1,int d2,int d3,int d4,int d5,int d6,int d7)
{


          if((d0 < 0x10)||(d0==0x30))
          {
          	DIAG_Req_XCP.DLC = 15; 
          	req[0] = DIAG_Req_XCP.BYTE(0) = d0;
          	req[1] = DIAG_Req_XCP.BYTE(1) = d1;
            req[2] = DIAG_Req_XCP.BYTE(2) = d2; 
          	req[3] = DIAG_Req_XCP.BYTE(3) = d3;
          	req[4] = DIAG_Req_XCP.BYTE(4) = d4;
          	req[5] = DIAG_Req_XCP.BYTE(5) = d5;
          	req[6] = DIAG_Req_XCP.BYTE(6) = d6;
          	req[7] = DIAG_Req_XCP.BYTE(7) = d7;
            DIAGNOSTIC_REQUEST("",req,8);
            Output(DIAG_Req_XCP);  
          }
          else if (d0 >= 0x10) 
          {
             	DIAG_Req_XCP.DLC = 15; 
            	req[0] = DIAG_Req_XCP.BYTE(0) = d0;
            	req[1] = DIAG_Req_XCP.BYTE(1) = d1;
				      req[2] = DIAG_Req_XCP.BYTE(2) = d2; 
            	req[3] = DIAG_Req_XCP.BYTE(3) = d3;
            	req[4] = DIAG_Req_XCP.BYTE(4) = d4;
            	req[5] = DIAG_Req_XCP.BYTE(5) = d5;
            	req[6] = DIAG_Req_XCP.BYTE(6) = d6;
            	req[7] = DIAG_Req_XCP.BYTE(7) = d7;
              DIAGNOSTIC_REQUEST("",req,8);
              Output(DIAG_Req_XCP);
              testwaitfortimeout(16);        
          }
}


