  DIAG_Req.dlc = 8; 
  DIAG_Req.byte(0)=  0x06; 
  DIAG_Req.byte(1)=  0x19; 
  DIAG_Req.byte(2)=  0x06; 
  DIAG_Req.byte(3)=  (DTC_NUM & 0xFF0000) >> 16; 
  DIAG_Req.byte(4)=  (DTC_NUM & 0x00FF00) >> 8; 
  DIAG_Req.byte(5)=  DTC_NUM & 0x0000FF ; 
  DIAG_Req.byte(6)=  0xFF; 
  output(DIAG_Req); 
  testWaitForTimeout(500);
  //OBSERVED_DATA("",O_Resp,16);    
 //   AddToReport();
    backup=(timeNowFloat()/100);
    if((backup-T1)>=12000)
    {
      break;
    }
    
  }
  
  if((backup-T1)<=12000)
  {
  T2=(timeNowFloat()/100);
  QulaTime = T2-T1;
   OBSERVED("De qualification time is  : ",QulaTime);
    AddToReport();
  }
  else{
    OBSERVED("\n Fault Not DeQualified"); 
    AddToReport(FAILED);
  }
  
}

