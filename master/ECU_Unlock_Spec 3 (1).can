testcase TC1_PGS_200624()
  {
    char logPath[256] = "C:\\Users\\GID_GMSDV_ITV\\Documents\\ECU_Unlock_logs\\PGS_200624.asc"; // Change this to your desired path
    setLogFileName("Test Logs",logPath);
    startLogging("Test Logs");
    
    /*-------------------------------Test Step 1--------------------------------------*/ 
    /*-----------------------------ACTION: set Battery voltage to 12v -----------------------------------*/
   
    Set_Bat_Vol(12);
    
    /*-------------------------------Test Step 2--------------------------------------*/ 
    /*-----------------------------ACTION: Read MEC -----------------------------------------*/   
    
    Read_MEC();
    
    /*-------------------------------Test Step 3--------------------------------------*/ 
    /*-----------------------------ACTION: Set powermode to OFF -----------------------------------------*/
    @IgnitionSwitch=0;
    Read_PowerMode();
    
    /*-------------------------------Test Step 4--------------------------------------*/ 
    /*-----------------------------ACTION: Enter Default Session ----------------------------------------*/
    Default_Session_Phy();
    
    /*-------------------------------Test Step 5--------------------------------------*/ 
    /*-----------------------------ACTION: Enter Extended Session ---------------------------------------*/
    Extended_Session_Phy();

    /*-------------------------------Test Step 6--------------------------------------*/ 
    /*-----------------------------ACTION: Disable Communication-----------------------------------------*/
    Dis_Comm_phy();
    
    /*-------------------------------Test Step 7--------------------------------------*/ 
    /*-----------------------------ACTION: Disable DTC---------------------------------------------------*/
    Dis_DTC_Phy();
    
    /*-------------------------------Test Step 8--------------------------------------*/ 
    /*-----------------------------ACTION: Activating Tester Present for every 2sec----------------------*/
   
    Tester_Present_Per_Start_Fun(2000);
    
    /*-------------------------------Test Step 9--------------------------------------*/ 
    /*-----------------------------ACTION: Security unlock Level 1----------------------------------------*/
    ACTION("Checking whether a valid Seed [non-zero, non-FF] for Security Level 01 is recieved or not");
    Security_Unlock_With_Key_lvl_1_Phy();
    
    testWaitForTimeout(2000);
    /*-------------------------------Test Step 10--------------------------------------*/ 
    /*-----------------------------ACTION: Enter Programming_Session-------------------------------------*/
     Programming_Session_Phy();
    
    /*-------------------------------Test Step 11--------------------------------------*/ 
    /*-----------------------------ACTION: Enter Programming_Session-------------------------------------*/
    
    STEP();
    ACTION("Enter Programming_Session"); 
    send_on_CAN(0x02,0x10,0x02,0x55,0x55,0x55,0x55,0x55);
    testWaitForTimeout(100);
    Expect(0x03,0x7F,0x10,0x33,0x55,0x55,0x55,0x55);
    EXPECTED_DATA("",E_Resp,0X08);
    OBSERVED_DATA("",O_Resp,0X08);
    Check(E_Resp,O_Resp);  
    Clear_Buffer();   

    testWaitForTimeout(1000);
    
    /*-------------------------------Test Step 12--------------------------------------*/ 
    /*-----------------------------ACTION: Setting ECU to Normal mode -----------------------------------*/
    
    Back_To_Normal();

    stopLogging("Test Logs");
  }
  
testcase TC2_PGS_200623()
  {
    char logPath[256] = "C:\\Users\\GID_GMSDV_ITV\\Documents\\ECU_Unlock_logs\\PGS_200623.asc"; // Change this to your desired path
    setLogFileName("Test Logs",logPath);
    startLogging("Test Logs");
    
    /*-------------------------------Test Step 1--------------------------------------*/ 
    /*-----------------------------ACTION: set Battery voltage to 12v -----------------------------------*/
    
    Set_Bat_Vol(12);
    
    /*-------------------------------Test Step 2--------------------------------------*/ 
    /*-----------------------------ACTION: Read MEC -----------------------------------------*/   
    
    Read_MEC();
    
    /*-------------------------------Test Step 3--------------------------------------*/ 
    /*-----------------------------ACTION: Set powermode to OFF -----------------------------------------*/
    
    @IgnitionSwitch=0;
    Read_PowerMode();
    
    /*-------------------------------Test Step 4--------------------------------------*/ 
    /*-----------------------------ACTION: Enter Extended Session ---------------------------------------*/
   
    Extended_Session_Phy();
    
    /*-------------------------------Test Step 5--------------------------------------*/ 
    /*-----------------------------ACTION: Activating Tester Present for every 2sec----------------------*/
   
    Tester_Present_Per_Start_Fun(2000);
    
    /*-------------------------------Test Step 6--------------------------------------*/ 
    /*-----------------------------ACTION: Security unlock Level 9----------------------------------------*/
    ACTION("Checking whether a valid Seed [non-zero, non-FF] for Security Level 09 is recieved or not");
    Security_Unlock_With_Key_lvl_9_Phy();
    
    testWaitForTimeout(1000);
    /*-------------------------------Test Step 7--------------------------------------*/ 
    /*-----------------------------ACTION: Writing DID F080  --------------------------------------------*/
    
    
    STEP();
    ACTION("Write DID F080 "); //Write DID F080  
    send_on_CAN(0x04,0x2E,0xF0,0x80,0x00,0x55,0x55,0x55);                           //We can able to write only one time if we want to check again then need to flash and Regionalization the ECU.
    testWaitForTimeout(100);
    Expect(0x03,0x6E,0xF0,0x80,0xAA,0xAA,0xAA,0xAA);
    EXPECTED_DATA("",E_Resp,0X08);
    OBSERVED_DATA("",O_Resp,0X08);
    Check(E_Resp,O_Resp);  
    Clear_Buffer();   

    testWaitForTimeout(1000);
    
    /*-------------------------------Test Step 8--------------------------------------*/ 
    /*-----------------------------ACTION: Enter Extended Session ---------------------------------------*/
    
    Extended_Session_Phy();
    
    /*-------------------------------Test Step 9--------------------------------------*/ 
    /*-----------------------------ACTION: Writing DID F080  --------------------------------------------*/
  
    
    STEP();
    ACTION("Write DID F080 "); //Write DID F080  
    send_on_CAN(0x04,0x2E,0xF0,0x80,0x00,0x55,0x55,0x55);
    testWaitForTimeout(100);
    Expect(0x03,0x7F,0x2E,0x33,0xAA,0xAA,0xAA,0xAA);
    EXPECTED_DATA("",E_Resp,0X08);
    OBSERVED_DATA("",O_Resp,0X08);
    Check(E_Resp,O_Resp);  
    Clear_Buffer();   

    testWaitForTimeout(1000);
    
    /*-------------------------------Test Step 10--------------------------------------*/ 
    /*-----------------------------ACTION: Setting ECU to Normal mode -----------------------------------*/
    
    Back_To_Normal();
  }

