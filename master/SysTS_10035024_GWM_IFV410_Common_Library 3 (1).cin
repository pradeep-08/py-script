Session(byte yy)
{
  
  DIAG_Req.dlc = 8;
  DIAG_Req.byte(0) = 0x2 ; 
  DIAG_Req.byte(1) = 0x10 ; 
  DIAG_Req.byte(2) = yy ;
  output(DIAG_Req); 
  testwaitfortimeout(100);
  Step();

  if(yy==0x01)
    Action("Enter into Default Session");
  else if(yy==0x02)
    Action("Enter into Programming Session");
  else
    Action("Enter into Extended Session");
  
  DIAGNOSTIC_REQUEST("",Tx_buffer,8);
  OBSERVED_DATA("",O_Resp,8);
  Expect(0x06,0x50,yy,0x00,0x32,0x01,0xF4,0x00);
  EXPECTED_DATA("",E_Resp,8);
  Check(O_Resp,E_Resp,8);
  
}

