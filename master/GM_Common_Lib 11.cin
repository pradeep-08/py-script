/****************************************************************************************/
void Back_To_Normal()
{
  @IgnitionSwitch =0;
  //@APT_Tester_Present_Stop=1;
  send_on_CAN(0x02,0x10,0x01,0x55,0x55,0x55,0x55,0x55);
  testWaitForTimeout(500);
  send_on_CAN(0x02,0x11,0x01,0x00,0x00,0x00,0x00,0x00);
  testWaitForTimeout(500);
  SetBattVoltage(12.00);

  testWaitForTimeout(500);
  
}

/****************************************************************************************/
void MEC_Equal_to_Zero()
{
      STEP();
      ACTION("Checking MEC Value");                                                   //Checking MEC because we can't wirte MEC more than 1 time
      send_on_CAN(0x03,0x22,0xF1,0xA0,0x00,0x00,0x00,0x00);
      testWaitForTimeout(100);
      Expect(0x04,0x62,0xF1,0xA0,O_Resp[4],0xAA,0xAA,0xAA);
      EXPECTED_DATA("",E_Resp,8);
      OBSERVED_DATA("",O_Resp,8);
      Check(E_Resp,O_Resp);
      if (O_Resp[4]!=0)
      { 
          Clear_Buffer();
          STEP();
          ACTION("Writing MEC Value");                                                   //Writing MEC value as Zero when MEC > Zero
          send_on_CAN(0x04,0x2E,0xF1,0xA0,0x00,0x55,0x55,0x55);
          testWaitForTimeout(100);
          Expect(0x04,0x6E,0xF1,0xA0,0x00,0xAA,0xAA,0xAA);
          EXPECTED_DATA("",E_Resp,8);
          OBSERVED_DATA("",O_Resp,8);
          Check(E_Resp,O_Resp);
          write("MEC not equal to zero");

          Clear_Buffer();
        
       
      }
      else 
      {
        write("MEC equal to zero");
        Clear_Buffer();
        
      }
    
}
/****************************************************************************************/
int Read_MEC()
{
    STEP();
    ACTION("Read MEC"); //Read MEC
    send_on_CAN(0x03,0x22,0xF1,0xA0,0x00,0x00,0x00,0x00);
    testWaitForTimeout(50);
    Expect(0x04,0x62,0xF1,0xA0,O_Resp[4],0xAA,0xAA,0xAA);
    EXPECTED_DATA("",E_Resp,8);
    OBSERVED_DATA("",O_Resp,8);
    Check(E_Resp,O_Resp); 
    
    if(O_Resp[4]==0)
    {
      mec_value = 0;
    }
    else
    {
      mec_value = 1;
    }
    
    return mec_value;
    
    Clear_Buffer();    
}
/****************************************************************************************/
void Write_RID_21E()
{
    STEP();
    ACTION("Writing RID 21E"); //Writing RID 21E                                      
    send_on_CAN(0x04,0x31,0x01,0x02,0x1E,0x00,0x00,0x00);
    testWaitForTimeout(100);
    Expect(0x05,0x71,0x01,0x02,0x1E,0x00,0xAA,0xAA);
    EXPECTED_DATA("",E_Resp,8);
    OBSERVED_DATA("",O_Resp,8);
    Check(E_Resp,O_Resp);  
    Clear_Buffer();   
    
    
    testWaitForTimeout(500);
}
/****************************************************************************************/
void Read_DID_F0F3()
{
    STEP();
    ACTION("READ DID F0F3"); 
    send_on_CAN(0x03,0x22,0xF0,0xF3,0x55,0x55,0x55,0x55);
    testWaitForTimeout(50);
    Expect1(0x10,0x13,0x62,0xF0,0xF3,0x7B,0xCB,0x78);
    testWaitForTimeout(50);
    Expect2(0x21,0x3C,0x00,0x01,0x43,0x00,0xC0,0x00);
    testWaitForTimeout(50); 
    Expect3(0x22,0x00,0x00,0x00,0xF2,0x85,0x2B,0XAA);
    EXPECTED_DATA("",E_Resp,32);
    OBSERVED_DATA("",O_Resp,32);
    Check(E_Resp,O_Resp);  
    Clear_Buffer();   

    testWaitForTimeout(500);
}
