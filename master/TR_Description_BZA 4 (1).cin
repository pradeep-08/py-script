/** 

@brief _Long_To_Bin_Str

 

Function converts input data into binary string

 

@param data input data that will be converted

@param strReturn converted data is passed to this parameter

@return  result(0)

 

*/

 

_Long_To_Bin_Str (dword dwData, char strReturn[])

{

    byte bIdx, i;

    byte bBit;

 

    if(dwData < (dword)0x100)

    {

        bIdx = 8;

    }

    else if(dwData < (dword)0x10000)

    {

        bIdx = 18;

    }

    else if(dwData < (dword)0x1000000)

    {

        bIdx = 28;

    }

    else

    {

        bIdx = 38;

    }

 

    strReturn[bIdx + 1] = 0;  // str termination

    i = 1;

 

    while(bIdx > 0)

    {

        bBit = dwData & 0x01;        

        if(0 == i % 5)

        {

            strReturn[bIdx--] = ' ';

            i = 1;

        }

 

        if(1 == bBit)

        {

            strReturn[bIdx] = '1';

        }

        else

        {

            strReturn[bIdx] = '0';

        }

        dwData = dwData >> 1;

        i++;

        bIdx--;

    }

    

    if(1 == dwData & 0x01)

    {

        strReturn[bIdx] = '1';

    }

    else

    {

        strReturn[bIdx] = '0';

    }

}

