/** 
@brief Steart test report.

This function generates header of test cese, add informiation on begining of every test case in test report.

@param sTCIdentifier[] Uniqe identificator of Test Case
@param sTitle[] Title of Test Case
@param sDescription[] Description of Test Case
@param sReq[] List of requirements followed by ","
@param sParams[] List of parameters to control priority etc.
@return  long error indicator
@author KHO
*/
long Init_Test_Case_Report (char sDescription[], char sReq[], char sParams[])
{
    long lresult;
    char strTemp[MAX_STR_LEN];
    long lStrLen;

    wTestStepID = 0;

    wShowTestStepID = FALSE;

    _Clear_All_Data_Strings();

    //TestCaseTitle("", sTitle);
    TestCaseDescription(sDescription);

    //testReportAddMiscInfoBlock("TCID:");
    //testReportAddMiscInfo("TCID", sTCIdentifier);

    if(wLengthOfTestCaseRequirementString > 0)
    {
        if(strLen(sReq) > 0)
            lStrLen = snprintf(strTemp,MAX_STR_LEN,"%s;%s",sReq,strTestCaseRequirementString);         
        else
            lStrLen = snprintf(strTemp,MAX_STR_LEN,"%s",strTestCaseRequirementString);
    }
    else
    {
        lStrLen = snprintf(strTemp,MAX_STR_LEN,"%s",sReq);
    } 
    //
    //
    wLengthOfTestCaseRequirementString = 0;
    strTestCaseRequirementString[0] = 0;

    testReportAddMiscInfoBlock("Requirements:");
    testReportAddMiscInfo("REQ", strTemp);

    testReportAddMiscInfoBlock("Parameters:");
    testReportAddMiscInfo("PARAMS", sParams);

    return lresult;
}

long TC_Req (char sReq_to_add[])
{
    long lResult;
    char strTemp[MAX_STR_LEN];
    long lStrLen;

    if(wLengthOfTestCaseRequirementString > 0)
    {
        lStrLen = snprintf(strTemp,MAX_STR_LEN,";%s",sReq_to_add);        
        strncat(strTestCaseRequirementString, strTemp, MAX_STR_LEN);  
    }
    else
    {
        lStrLen = snprintf(strTestCaseRequirementString,MAX_STR_LEN,"%s",sReq_to_add);
    } 
    
    wLengthOfTestCaseRequirementString = strlen(strTestCaseRequirementString); 

    Return lResult;
}

