/** 
@brief EXPECTED_DATA

Function to add string to "expected_data" field.
String is added at the end of "expected_data" field

@param string input string
@param data input data
@return  result(0)
@author BZA & PLE
*/

long EXPECTED_DATA (char string[], long data)
{
    long lResult;
    char strTemp[MAX_STR_LEN];
    long lStrLen;
    
    if(wExpected_DataLen > 0)
    {
        lStrLen = snprintf(strTemp,MAX_STR_LEN,"\n%s %ld",string, data);
        strncat(strExpected_Data, strTemp, MAX_STR_LEN);
    }
    else
    {
        lStrLen = snprintf(strExpected_Data,MAX_STR_LEN,"%s %ld",string, data);  
    }   
    
    wExpected_DataLen = strlen(strExpected_Data); 

    Return lResult;
}

