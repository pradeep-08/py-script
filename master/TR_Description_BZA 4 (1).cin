long OBSERVED_DATA (char string[], byte data[], int data_length)
{
    long lResult;
    char strTemp[MAX_STR_LEN];
    char strByte[4];
    long lStrLen;
    word i;
    
    if(wObserved_DataLen > 0)
    {
        lStrLen = snprintf(strTemp,MAX_STR_LEN,"\n%s",string);
        strncat(strObserved_Data, strTemp, MAX_STR_LEN);   
    }
    else
    {
        lStrLen = snprintf(strObserved_Data,MAX_STR_LEN,"%s",string);
    }

    for(i=0; i < data_length; i++)
    {
        if(data[i] < 0x10)
        {
            snprintf(strByte, 4, " 0%X", data[i]);
        }
        else
        {
            snprintf(strByte, 4, " %X", data[i]);
        }
        strncat(strObserved_Data, strByte, MAX_STR_LEN);
    }
    
    wObserved_DataLen = strlen(strObserved_Data); 

    Return lResult;
}

