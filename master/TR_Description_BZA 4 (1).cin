long TestcaseID_DATA (char string[], int data)
{
    long lResult;
    char strTemp[MAX_STR_LEN];
    long lStrLen;
    
    if(wTestcaseID_DATA > 0)
    {
        lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s%ld",string, data);
        strncat(strTestcaseID_DATA, strTemp, MAX_STR_LEN);
    }
    else
    {
        lStrLen = snprintf(strTestcaseID_DATA,MAX_STR_LEN,"%s%ld",string, data);  
    }       
    
    wTestcaseID_DATA = strlen(strTestcaseID_DATA); 

    Return lResult;
}  


long REQUIREMENT_DATA (char string[]) 
{ 
    long lResult; 
    char strTemp[MAX_STR_LEN]; 
    long lStrLen;  

    if(wActionLen > 0) 
    { 
        lStrLen = snprintf(strTemp,MAX_STR_LEN,"\n%s",string);        
        strncat(strRequirement, strTemp, MAX_STR_LEN);  
    } 
    else 
    { 
        lStrLen = snprintf(strRequirement,MAX_STR_LEN,"%s",string); 
    } 
    
    wRequirement = strlen(strRequirement); 

    Return lResult; 
}

