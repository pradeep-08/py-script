void power()
{
  setTimer(t1,200);
}
on timer t1
{
    //setSignal(CAN_1_Cluster::SysPwrMode_Prtctd_PDU::SPMP_SysPwrModeAuth,4);
    setTimer(t1,200);
}

/****************************************************************************************/
void Read_PowerMode()
{
   
   
    switch (@IgnitionSwitch)
  {
    case 0:
          STEP();
          ACTION("Read_PowerMode"); //Read_PowerMode
          send_on_CAN(0x03,0x22,0xF0,0x85,0x55,0x55,0x55,0x55);
          testWaitForTimeout(100);
          Expect(0x04,0x62,0xF0,0x85,0x00,0xAA,0xAA,0xAA);
          EXPECTED_DATA("",E_Resp,8);
          OBSERVED_DATA("",O_Resp,8);
          Check(E_Resp,O_Resp);  
          Clear_Buffer();   
    
          testWaitForTimeout(1000);
    break;

    case 1:
          STEP();
          ACTION("Read_PowerMode"); //Read_PowerMode
          send_on_CAN(0x03,0x22,0xF0,0x85,0x55,0x55,0x55,0x55);
          testWaitForTimeout(100);
          Expect(0x04,0x62,0xF0,0x85,0x01,0xAA,0xAA,0xAA);
          EXPECTED_DATA("",E_Resp,8);
          OBSERVED_DATA("",O_Resp,8);
          Check(E_Resp,O_Resp);  
          Clear_Buffer();   
    
          testWaitForTimeout(1000);
    break;

    case 2:
          STEP();
          ACTION("Read_PowerMode"); //Read_PowerMode
          send_on_CAN(0x03,0x22,0xF0,0x85,0x55,0x55,0x55,0x55);
          testWaitForTimeout(100);
          Expect(0x04,0x62,0xF0,0x85,0x02,0xAA,0xAA,0xAA);
          EXPECTED_DATA("",E_Resp,8);
          OBSERVED_DATA("",O_Resp,8);
          Check(E_Resp,O_Resp);  
          Clear_Buffer();   
    
          testWaitForTimeout(1000);
    break;

    case 3:
          STEP();
          ACTION("Read_PowerMode"); //Read_PowerMode
          send_on_CAN(0x03,0x22,0xF0,0x85,0x55,0x55,0x55,0x55);
          testWaitForTimeout(100);
          Expect(0x04,0x62,0xF0,0x85,0x03,0xAA,0xAA,0xAA);
          EXPECTED_DATA("",E_Resp,8);
          OBSERVED_DATA("",O_Resp,8);
          Check(E_Resp,O_Resp);  
          Clear_Buffer();   
    
          testWaitForTimeout(1000);
    break;
      
    case 4:
        STEP();
        ACTION("Read_PowerMode"); //Read_PowerMode
        send_on_CAN(0x03,0x22,0xF0,0x85,0x55,0x55,0x55,0x55);
        testWaitForTimeout(100);
        Expect(0x04,0x62,0xF0,0x85,0x04,0xAA,0xAA,0xAA);
        EXPECTED_DATA("",E_Resp,8);
        OBSERVED_DATA("",O_Resp,8);
        Check(E_Resp,O_Resp);  
        Clear_Buffer();   
    
        testWaitForTimeout(1000);
    break;

    default:
        write("Unable to find");
    break;
  }

}
/****************************************************************************************/
void Default_Session_Phy()
{
    STEP();
    ACTION("Enter Default Session"); //Default Session
    send_on_CAN(0x02,0x10,0x01,0x55,0x55,0x55,0x55,0x55);
    testWaitForTimeout(100);
    Expect(0x06,0x50,0x01,0x00,0x64,0x01,0xF4,0xAA);
    EXPECTED_DATA("",E_Resp,8);
    OBSERVED_DATA("",O_Resp,8);
    Check(E_Resp,O_Resp);  
    Clear_Buffer();   
    
    
    testWaitForTimeout(1000);
}
