/****************************************************************************************/
void Security_Unlock_Seed_lvl_01_Phy()
{
    STEP();
    ACTION("Security unlock seed 1"); //Security unlock seed 1
    send_on_CAN(0x02,0x27,0x01,0x55,0x55,0x55,0x55,0x55);
    testWaitForTimeout(100);
                Expect1(0x10,0x21,0x67,0x01,O_Resp[4],O_Resp[5],O_Resp[6],O_Resp[7]);
                testWaitForTimeout(50);
                Expect2(O_Resp[8],O_Resp[9],O_Resp[10],O_Resp[11],O_Resp[12],O_Resp[13],O_Resp[14],O_Resp[15]);
                testWaitForTimeout(50);
                Expect3(O_Resp[16],O_Resp[17],O_Resp[18],O_Resp[19],O_Resp[20],O_Resp[21],O_Resp[22],O_Resp[23]);
                testWaitForTimeout(50);
                Expect4(O_Resp[24],O_Resp[25],O_Resp[26],O_Resp[27],O_Resp[28],O_Resp[29],O_Resp[30],O_Resp[31]);
                testWaitForTimeout(50);
                Expect5(O_Resp[32],O_Resp[33],O_Resp[34],O_Resp[35],O_Resp[36],O_Resp[37],O_Resp[38],O_Resp[39]);
                testWaitForTimeout(50);
                EXPECTED_DATA("",E_Resp,40);
                OBSERVED_DATA("",O_Resp,40);
                Check(E_Resp,O_Resp);
                Clear_Buffer();
    testWaitForTimeout(5000);
}
