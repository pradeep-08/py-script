/** 
@brief OBSERVED_DATA

Function to add string to "observed_data" field.
String is added at the end of "observed_data" field

@param string input string
@param data input byte
@param data_lenght_start contains start of data field
@param data_length_end contains last byte of data field
@return  result(0)
@author BZA & PLE
*/

long OBSERVED_DATA (char string[], byte data[], int data_length_start, int data_length_end, char string_2[])
{
    long lResult;
    char strTemp[MAX_STR_LEN];
    char strByte[4];
    long lStrLen;
    byte i;
    
    if(wObserved_DataLen > 0)
    {
        lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s",string);
        strncat(strObserved_Data, strTemp, MAX_STR_LEN);   
    }
    else
    {
        lStrLen = snprintf(strObserved_Data,MAX_STR_LEN,"%s",string);
    }

    for(i=data_length_start; i < data_length_end; i++)
    {
        if(data[i] < 0x10)
        {
            snprintf(strByte, 4, " 0%X", data[i]);
        }
        else
        {
            snprintf(strByte, 4, " %X", data[i]);
        }
        strncat(strObserved_Data, strByte, MAX_STR_LEN);
    }

    snprintf(strTemp, MAX_STR_LEN," %s ",string_2);

    strncat(strObserved_Data, strTemp, MAX_STR_LEN);
    
    wObserved_DataLen = strlen(strObserved_Data); 

    Return lResult;
}

