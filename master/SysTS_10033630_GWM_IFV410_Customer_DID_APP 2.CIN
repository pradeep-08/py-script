    Expect8(0x27,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect9(0x28,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect10(0x29,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    EXPECTED_DATA("",E_Resp,80);
  
    //////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Set Voltage to 16.5v ");
    STEP();
    SetBattVoltage(16.5);
    Add_To_Report(PASSED);
  
	 ///////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("set voltage to 12 v");
    STEP();
    SetBattVoltage(12);
    Add_To_Report(PASSED);
  
  ///////////////////////////////////////////////////////////////
    
    testWaitForTimeout(2000);
  	STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Enter Default Session");
    STEP();
    send_on_CAN(0x02,0x10,0x01,0x00,0x00,0x00,0x00,0x00);
    testWaitForTimeout(100);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x06,0x50,0x01,0x00,0x32,0x01,0xF4,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp);   
    Clear_Buffer();
  ///////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Read DID and check if the value remains same after reset.");
    STEP();
    send_on_CAN(0x03,0x22,DID_H,DID_L,0x00,0x00,0x00,0x00);
    testWaitForTimeout(500);
    OBSERVED_DATA("",O_Resp,80);
    Expect1(0x10,0x43,0x62,DID_H,DID_L,0x00,0x00,0x00);
    Expect2(0x21,0x00,0x00,0x00,0xA0,0x00,0x00,0x00);
    Expect3(0x22,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect4(0x23,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect5(0x24,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect6(0x25,0x40,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect7(0x26,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect8(0x27,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect9(0x28,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect10(0x29,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    EXPECTED_DATA("",E_Resp,80);
  
  return DTCStepCount;
}


/**********************Internal_DID_Functions******************************/
/*                     Host Revision and Checksum - 7500                  */
/**************************************************************************/

int Default_Session_Phy_TestCase_Host_Checksum(char TestcaseIDD[],int DTCStepCount,int DID_H,int  DID_L)
{
    

    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Enter Default Session");
    STEP();
    send_on_CAN(0x02,0x10,0x01,0x00,0x00,0x00,0x00,0x00);
    testWaitForTimeout(100);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x06,0x50,0x01,0x00,0x32,0x01,0xF4,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp); 
    Clear_Buffer();
  
    //////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Read DID in Default Session with Default Value");
    STEP();
    send_on_CAN(0x03,0x22,DID_H,DID_L,0x00,0x00,0x00,0x00);
    testWaitForTimeout(500);
    OBSERVED_DATA("",O_Resp,24);
    Expect1(0x10,0x11,0x62,DID_H,DID_L,0x01,0x00,0x00);
    Expect2(0x21,0x8E,0x54,0x7F,0x13,0x01,0x00,0x00);
    Expect3(0x22,0x00,0x00,0x00,0x00,0xCC,0xCC,0xCC);
    EXPECTED_DATA("",E_Resp,24);
    Check(E_Resp,O_Resp,24);
    Clear_Buffer();
  
    ////////////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Write DID in Default Session");
    STEP();
    Write1(0x10,0x11,0x2E,DID_H,DID_L,0xFF,0xFF,0xFF);
    Write2(0x21,0xFF,0xFF,0xFF,0xFF,0xFF,0xFF,0xFF);
    Write3(0x22,0xFF,0xFF,0xFF,0xFF,0x00,0x00,0x00);  
    Write_did(DID_H,DID_L,0x11);
    testWaitForTimeout(100);
    DIAGNOSTIC_REQUEST("",Tx_buffer,24);
    testWaitForTimeout(200);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x03,0x7F,0x2E,0x7F,0xCC,0xCC,0xCC,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp,8);
    clear_buffer();
  
  return DTCStepCount;
}

