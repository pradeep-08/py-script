Write_did(byte DIDHigh,byte DIDLow,long len)
 {

    int p1;
    
    
    Step();
    l_temp1 = len+5;
    //l_temp1 = len;
      write("%d",l_temp1);

    for(p1=0;p1<1000;p1++)
    {
    write_array_buff[p1] = W_array[p1] ;      
    }
    
     if(len < 8 )
     {
      DIAG_Req.dlc = len+1;
//      DIAG_Req.byte(0)= len;
//      DIAG_Req.byte(1)= 0x2E;
//      DIAG_Req.byte(2)=  DIDHigh;
//      DIAG_Req.byte(3)=  DIDLow;
      for(i=0;i<8;i++)
      {
      DIAG_Req.byte(i)= write_array_buff[i] ;
      }
      output(DIAG_Req);
     }
     else
     {
      DIAG_Req.dlc = 8;
//      DIAG_Req.byte(0)= 0x10;
//      DIAG_Req.byte(1)= len;
//      DIAG_Req.byte(2)= 0x2E ;
//      DIAG_Req.byte(3)=  DIDHigh;
//      DIAG_Req.byte(4)=  DIDLow;
      for(data_pack_cnt=0;data_pack_cnt<8;data_pack_cnt++)
       { 
          DIAG_Req.byte(data_pack_cnt)= write_array_buff[data_pack_cnt] ;
       }
      output(DIAG_Req);
      length_cnt = 0x21;
      data_pack_cnt = 8;// have written 8 bytes of data.
      setTimer(Data_Sending1,50);
      testwaitfortimeout(500);
     }
     
 }

Write_did_FUN(byte DIDHigh,byte DIDLow,long len)
 {

    int p1;
    
    
      Step();
    l_temp1 = len+5; 
  write("%d",l_temp1);
    for(p1=0;p1<1000;p1++)
    {
    write_array_buff[p1] = W_array[p1] ;      
    }
    
     if(len < 8 )
     {
      FUN_Req.dlc = len+1;
//      FUN_Req.byte(0)= len;
//      FUN_Req.byte(1)= 0x2E;
//      FUN_Req.byte(2)=  DIDHigh;
//      FUN_Req.byte(3)=  DIDLow;
      for(i=0;i<8;i++)
      {
      FUN_Req.byte(i)= write_array_buff[i] ;
      }
      output(FUN_Req);
     }
     else
     {
      FUN_Req.dlc = 8;
//      FUN_Req.byte(0)= 0x10;
//      FUN_Req.byte(1)= len;
//      FUN_Req.byte(2)= 0x2E ;
//      FUN_Req.byte(3)=  DIDHigh;
//      FUN_Req.byte(4)=  DIDLow;
      for(data_pack_cnt=0;data_pack_cnt<8;data_pack_cnt++)
       { 
          FUN_Req.byte(data_pack_cnt)= write_array_buff[data_pack_cnt] ;
       }
      output(FUN_Req);
      length_cnt = 0x21;
      data_pack_cnt = 8;// have written 3 bytes of data.
      setTimer(FUN_Data_Sending1,50);
      testwaitfortimeout(500);
     }
     
 }

