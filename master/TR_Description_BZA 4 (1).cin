@brief ACTION

Function to add string and data to "action" field.
String is added at the end of "action" field

@param string input string
@param data input byte
@param data_lenght_start contains start of data field
@param data_length_end contains last byte of data field
@return  result(0)
@author BZA & PLE
*/

long ACTION (char string[], byte data[], int data_length_start, int data_length_end)
{
    long lResult;
    char strTemp[MAX_STR_LEN];
    char strByte[4];
    long lStrLen;
    byte i;
    
    if(wActionLen > 0)
    {
        lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s",string);
        strncat(strAction, strTemp, MAX_STR_LEN); 
    }
    else
    {
        lStrLen = snprintf(strAction,MAX_STR_LEN,"%s",string);
    }

    for(i=data_length_start; i < data_length_end; i++)
    {
        if(data[i] < 0x10)
        {
            snprintf(strByte, 4, " 0%X", data[i]);
        }
        else
        {
            snprintf(strByte, 4, " %X", data[i]);
        }
        strncat(strAction, strByte, MAX_STR_LEN);
    }
 
    wActionLen = strlen(strAction); 

    Return lResult;
}

/** 
@brief ACTION_DATA

Function to add string to "action_data" field.
String is added at the end of "action_data" field

@param string input string
@param data input data
@return  result(0)
