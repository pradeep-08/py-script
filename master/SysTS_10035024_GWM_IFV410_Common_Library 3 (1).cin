send_on_CAN (int d0,int d1,int d2,int d3,int d4,int d5,int d6,int d7)
{


          if((d0 < 0x10)||(d0==0x30))
          {
          	DIAG_Req.DLC = 8; //8
          	req[0] = DIAG_Req.BYTE(0) = d0;
          	req[1] = DIAG_Req.BYTE(1) = d1;
            req[2] = DIAG_Req.BYTE(2) = d2; 
          	req[3] = DIAG_Req.BYTE(3) = d3;
          	req[4] = DIAG_Req.BYTE(4) = d4;
          	req[5] = DIAG_Req.BYTE(5) = d5;
          	req[6] = DIAG_Req.BYTE(6) = d6;
          	req[7] = DIAG_Req.BYTE(7) = d7;
  		      DIAGNOSTIC_REQUEST(" 0x14DA59F1x   ",req,8);
            
            Output(DIAG_Req);  
          }
          else if (d0 >= 0x10) 
          {
           // Count =  (DIAG_Req.BYTE(1))/8;
       //    Count =  d1/8;
           // for(i = 1; i <= Count; i++)
          //  {
            	DIAG_Req.DLC = 8; 
            	req[0] = DIAG_Req.BYTE(0) = d0;
            	req[1] = DIAG_Req.BYTE(1) = d1;
              req[2] = DIAG_Req.BYTE(2) = d2; 
            	req[3] = DIAG_Req.BYTE(3) = d3;
            	req[4] = DIAG_Req.BYTE(4) = d4;
            	req[5] = DIAG_Req.BYTE(5) = d5;
            	req[6] = DIAG_Req.BYTE(6) = d6;
            	req[7] = DIAG_Req.BYTE(7) = d7;
    		      DIAGNOSTIC_REQUEST(" 0x14DA59F1x   ",req,8);
              
              Output(DIAG_Req);
         //   }
          }
          
}

