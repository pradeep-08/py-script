    if(wAction_DataLen > 0)
    {
        lStrLen = snprintf(strTemp,MAX_STR_LEN,"\\n%s %.3f %s",string, data, string_2);
        strncat(strAction_Data, strTemp, MAX_STR_LEN);  
    }
    else
    {
        lStrLen = snprintf(strAction_Data,MAX_STR_LEN,"%s %.3f %s",string, data, string_2);
    }
    
    wAction_DataLen = strlen(strAction_Data); 

    Return lResult;
}

