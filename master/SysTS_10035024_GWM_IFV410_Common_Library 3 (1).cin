void DTC_Qualifiction_time_Check_TEMP1(Long DTC_NUM )
{
   float T1=0xff,backup,T2= 0xFF,QulaTime=0; 
  int r;
  T1=(timeNowFloat()/100);
  
   for(r=0;r<400;r++)
  {
    
  DIAG_Req.dlc = 8; 
  DIAG_Req.byte(0)=  0x06; 
  DIAG_Req.byte(1)=  0x19; 
  DIAG_Req.byte(2)=  0x06; 
  DIAG_Req.byte(3)=  (DTC_NUM & 0xFF0000) >> 16; 
  DIAG_Req.byte(4)=  (DTC_NUM & 0x00FF00) >> 8; 
  DIAG_Req.byte(5)=  DTC_NUM & 0x0000FF ; 
  DIAG_Req.byte(6)=  0xFF; 
  output(DIAG_Req); 
  testWaitForTimeout(10);
 // OBSERVED_DATA("",O_Resp,16);    
 //   AddToReport();
    backup=(timeNowFloat()/100);
    if(((backup-T1)>=1000))
    {
      break;
    }
    if(O_Resp[7] == 0x2B) 
    {
      
      break;
    }
  }
  
  if((backup-T1)<1000)
  {
  T2=(timeNowFloat()/100);
  QulaTime = T2-T1;
   OBSERVED("Fault Qualified for inValid Value and qualification time is  : ",QulaTime);
    AddToReport();
  }
  else{
    OBSERVED("\n Fault Not Qualified for inValid Value"); 
    AddToReport(FAILED);
  }
  
}

void DTC_Qualifiction_time_Check_TEMP2(Long DTC_NUM )
{
   float T1=0xff,backup,T2= 0xFF,QulaTime=0; 
  int r;
  T1=(timeNowFloat()/100);
  
   for(r=0;r<400;r++)
  {
    
  DIAG_Req.dlc = 8; 
  DIAG_Req.byte(0)=  0x06; 
  DIAG_Req.byte(1)=  0x19; 
  DIAG_Req.byte(2)=  0x06; 
  DIAG_Req.byte(3)=  (DTC_NUM & 0xFF0000) >> 16; 
  DIAG_Req.byte(4)=  (DTC_NUM & 0x00FF00) >> 8; 
  DIAG_Req.byte(5)=  DTC_NUM & 0x0000FF ; 
  DIAG_Req.byte(6)=  0xFF; 
  output(DIAG_Req); 
  testWaitForTimeout(20);
 // OBSERVED_DATA("",O_Resp,16);    
 //   AddToReport();
    backup=(timeNowFloat()/100);
    if(((backup-T1)>=2000))
    {
      break;
    }
    if(O_Resp[7] == 0x2B) 
    {
      
      break;
    }
  }
  
  if((backup-T1)<=2000)
  {
  T2=(timeNowFloat()/100);
  QulaTime = T2-T1;
   OBSERVED("Fault Qualified for Valid value, for which fault should Reset and qualification time is  : ",QulaTime);
    AddToReport(FAILED);
  }
  else{
    OBSERVED("\n Fault Not Qualified for valid Value"); 
    AddToReport(PASSED);
  }
  
}

IFV300_REQ_SEED_PROG()
{
  send_on_CAN_bl (0x02,0x27,0x35,0x00,0x00,0x00,0x00,0x00);
  testWaitForTimeout(50);
  OBSERVED_DATA("",O_Resp,8);
  Expect(0x06,0x67,0x35,O_Resp[3],O_Resp[4],O_Resp[5],O_Resp[6],O_Resp[7]);
  EXPECTED_DATA("",E_Resp,8);
  check(E_Resp,O_Resp,8);
  GWM_KEY_VAL = IFV300_Calculate_KEY_PROG(O_Resp[3],O_Resp[4],O_Resp[5],O_Resp[6]);
  testWaitForTimeout(100);
  
}

long IFV300_Calculate_KEY_PROG( byte seed1,byte seed2,byte seed3,byte seed4)
{
  long key_val = 0;
  long seed_val;
  int i;
  seed_val = ((seed1<<24) +(seed2<<16) +(seed3<<8) + seed4) & 0xFFFFFFFF ;
  
                if (seed_val !=0)
                                {
                                                for (i=0;i<35;i++)
                                                {
                                                if (seed_val & 0x80000000)
                                                                {
                                                                seed_val = seed_val << 1;
                                                                seed_val = seed_val ^ 0x46354641;
                                                                }
                                                                else
                                                                {
                                                                seed_val = seed_val << 1;
                                                                }
                                                }
                                                key_val = seed_val;
                                }
  
  return key_val; 
}


IFV300_SEND_KEY_PROG()
{  
  
  byte key1,key2,key3,key4;
  key1= ((GWM_KEY_VAL>>24) & 0x000000FF);
  key2= ((GWM_KEY_VAL>>16) & 0x000000FF);
  key3= ((GWM_KEY_VAL>>8) & 0x000000FF);
  key4= (GWM_KEY_VAL&0x000000FF);
  Step();
  //ACTION("Send KEY"); 
  send_on_CAN_bl (0x06,0x27,0x36,key1,key2,key3,key4,0x00); 
  testWaitForTimeout(200);
  Expect(0x02,0x67,0x36,O_Resp[3],O_Resp[4],O_Resp[5],O_Resp[6],O_Resp[7]);
  OBSERVED_DATA("",O_Resp,8);
  EXPECTED_DATA("",E_Resp,8);
  check(E_Resp,O_Resp,8);
}

Void checkSignalvalue(float OBS, float EXP)
{
  if((OBS <= EXP+1.0)&& (OBS >= EXP-1.0))
    {
      OBSERVED("Observed Value of ",OBS);
      EXPECTED("Expected Value of ",EXP);
    Add_To_Report(PASSED);
    }
    else
    {
      OBSERVED("Observed Value of ",OBS);
      EXPECTED("Expected Value of ",EXP);
      Add_To_Report(FAILED);
    }
}
Check_DTC_SNAPSHOT(byte E_Resp[],byte O_Resp[],int len)
{ 
  for(i=0;i<len;i++)
  {
    if (i != 22)
    {
    if(E_Resp[i] == O_Resp[i])
    {
      count = count+1;
    }
    }
  }
  
  if(count == len-1)
  {
    Add_to_report(PASSED); 
    count=0;
  }
  else
  {
    Add_to_report(FAILED);  
    count=0;
  }
}
