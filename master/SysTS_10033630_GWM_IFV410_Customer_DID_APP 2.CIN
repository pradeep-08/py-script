    testWaitForTimeout(100);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x06,0x50,0x03,0x00,0x32,0x01,0xF4,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp);
    Clear_Buffer();
    //////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Enter Programming Session");
    STEP();
    send_on_CAN(0x02,0x10,0x02,0x00,0x00,0x00,0x00,0x00);
    testWaitForTimeout(100);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x06,0x50,0x02,0x00,0x32,0x01,0xF4,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp); 
    Clear_Buffer();
    //////////////////////////////////////////////////////////////////
    testWaitForTimeout(100);
  
   ////////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
