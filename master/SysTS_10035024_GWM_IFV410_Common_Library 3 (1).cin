on timer Data_Sending
{
            int j;
            testwaitfortimeout(50);
            if(data_pack_cnt < (l_temp-1) && length_cnt < 0x2F )
            {
            DIAG_Req.dlc = 8;
            DIAG_Req.byte(0)= length_cnt;
            for(j=1;j<=7;j++)
             { 
                DIAG_Req.byte(j)= write_array_buff[data_pack_cnt] ;
                data_pack_cnt++;
             }
            output(DIAG_Req);
            length_cnt++;
            //testStep("","Writeen %d bytes of data %d ",data_pack_cnt,(l_temp-1));
            setTimer(Data_Sending,5);
            }

}

