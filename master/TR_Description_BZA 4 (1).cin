        strncat(strObserved, strByte, MAX_STR_LEN);
    }

    snprintf(strTemp, MAX_STR_LEN," %s ",string_2);

    strncat(strObserved, strTemp, MAX_STR_LEN);
        
    wObservedLen = strlen(strObserved); 

    Return lResult;
}

