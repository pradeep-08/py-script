int Programming_Session_Functional_TestCase(char TestcaseIDD[],int DTCStepCount,int DID_H,int DID_L)
{
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Enter Extended Session");
    STEP();
