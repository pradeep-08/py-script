void DID_Write(byte DIDHigh,byte DIDLow,byte No_of_Bytes)
{
  if(No_of_Bytes <= 0x07)
   {
      DIAG_Req.dlc = 8;
      DIAG_Req.byte(0)=  No_of_Bytes;
      DIAG_Req.byte(1)=  0x2E;
      DIAG_Req.byte(2)=  DIDHigh ;
      DIAG_Req.byte(3)=  DIDLow;
      DIAG_Req.byte(4)=  W_array[0];
      DIAG_Req.byte(5)=  W_array[1];
      DIAG_Req.byte(6)=  W_array[2];
      DIAG_Req.byte(7)=  W_array[3];
      output(DIAG_Req);
      testwaitfortimeout(200);  
  }
  
  if(No_of_Bytes > 0x07)
   {
      DIAG_Req.dlc = 8;
      DIAG_Req.byte(0)=  0x10;
      DIAG_Req.byte(1)=  No_of_Bytes;
      DIAG_Req.byte(2)=  0x2E ;
      DIAG_Req.byte(3)=  DIDHigh;
      DIAG_Req.byte(4)=  DIDLow;
      DIAG_Req.byte(5)=  W_array[0];
      DIAG_Req.byte(6)=  W_array[1];
      DIAG_Req.byte(7)=  W_array[2];
      output(DIAG_Req);
      testwaitfortimeout(50); //100
   
    
      DIAG_Req.dlc = 8;
      DIAG_Req.byte(0)=  0x21;
      DIAG_Req.byte(1)=  W_array[3];
      DIAG_Req.byte(2)=  W_array[4];
      DIAG_Req.byte(3)=  W_array[5];
      DIAG_Req.byte(4)=  W_array[6];
      DIAG_Req.byte(5)=  W_array[7];
      DIAG_Req.byte(6)=  W_array[8];
      DIAG_Req.byte(7)=  W_array[9];
      output(DIAG_Req);
      testwaitfortimeout(50); 
     
  }
    
   if(No_of_Bytes > 0x0D)
  {
      DIAG_Req.dlc = 8;
      DIAG_Req.byte(0)=  0x22;
      DIAG_Req.byte(1)=  W_array[10];
      DIAG_Req.byte(2)=  W_array[11];
      DIAG_Req.byte(3)=  W_array[12];
      DIAG_Req.byte(4)=  W_array[13];
      DIAG_Req.byte(5)=  W_array[14];
      DIAG_Req.byte(6)=  W_array[15];
      DIAG_Req.byte(7)=  W_array[16];
      output(DIAG_Req);
      testwaitfortimeout(50); 
  }
  if (No_of_Bytes > 0x14)
  {
      DIAG_Req.dlc = 8;
      DIAG_Req.byte(0)=  0x23;
      DIAG_Req.byte(1)=  W_array[17];
      DIAG_Req.byte(2)=  W_array[18];
      DIAG_Req.byte(3)=  W_array[19];
      DIAG_Req.byte(4)=  W_array[20];
      DIAG_Req.byte(5)=  W_array[21];
      DIAG_Req.byte(6)=  W_array[22];
      DIAG_Req.byte(7)=  W_array[23];
      output(DIAG_Req);
      testwaitfortimeout(50);
  }
   if (No_of_Bytes > 0x1B)
  {
      DIAG_Req.dlc = 8;
      DIAG_Req.byte(0)=  0x24;
      DIAG_Req.byte(1)=  W_array[24];
      DIAG_Req.byte(2)=  W_array[25];
      DIAG_Req.byte(3)=  W_array[26];
      DIAG_Req.byte(4)=  W_array[27];
      DIAG_Req.byte(5)=  W_array[28];
      DIAG_Req.byte(6)=  W_array[29];
      DIAG_Req.byte(7)=  W_array[30];
      output(DIAG_Req);
      testwaitfortimeout(50);
  }
  if (No_of_Bytes > 0x22)
  {
      DIAG_Req.dlc = 8;
      DIAG_Req.byte(0)=  0x25;
      DIAG_Req.byte(1)=  W_array[31];
      DIAG_Req.byte(2)=  W_array[32];
      DIAG_Req.byte(3)=  W_array[33];
      DIAG_Req.byte(4)=  W_array[34];
      DIAG_Req.byte(5)=  W_array[35];
      DIAG_Req.byte(6)=  W_array[36];
      DIAG_Req.byte(7)=  W_array[37];
      output(DIAG_Req);
      testwaitfortimeout(50);
  }
      
      if(No_of_Bytes <= 0x07)
      DIAGNOSTIC_REQUEST("",W_array,8);
      
      if((No_of_Bytes>0x07)&& (No_of_Bytes<0x0D))
      DIAGNOSTIC_REQUEST("",W_array,16);
      
      if((No_of_Bytes>0x0D)&& (No_of_Bytes<0x14))
      DIAGNOSTIC_REQUEST("",W_array,24);
      
      if((No_of_Bytes>0x14)&& (No_of_Bytes<0x1B))
      DIAGNOSTIC_REQUEST("",W_array,32);
      
      if((No_of_Bytes>0x1B)&& (No_of_Bytes<0x22))
      DIAGNOSTIC_REQUEST("",W_array,40);
      
      if(O_Resp[0]==0x10)
     OBSERVED_DATA("",O_Resp,( O_Resp[1] + ((O_Resp[1] - 6)/7) + 3 ));
    else
     OBSERVED_DATA("",O_Resp,8);
      
      Expect1(0x03,0x6E,DIDHigh,DIDLow,0x00,0x00,0x00,0x00);
      EXPECTED_DATA ("",E_Resp,8);  
//      OBSERVED_DATA("",O_Resp,8);
      Check(E_Resp,O_Resp);
      testWaitForTimeout(2000); 
    
  }

void DID_Write_Func(byte DIDHigh,byte DIDLow,byte No_of_Bytes)
{
  if(No_of_Bytes <= 0x07)
   {
      FUN_Req.dlc = 8;
      FUN_Req.byte(0)=  No_of_Bytes;
      FUN_Req.byte(1)=  0x2E;
      FUN_Req.byte(2)=  DIDHigh ;
      FUN_Req.byte(3)=  DIDLow;
      FUN_Req.byte(4)=  W_array[0];
      FUN_Req.byte(5)=  W_array[1];
      FUN_Req.byte(6)=  W_array[2];
      FUN_Req.byte(7)=  W_array[3];
      output(FUN_Req);
      testwaitfortimeout(200);  
  }
  
  if(No_of_Bytes > 0x07)
   {
      FUN_Req.dlc = 8;
      FUN_Req.byte(0)=  0x10;
      FUN_Req.byte(1)=  No_of_Bytes;
      FUN_Req.byte(2)=  0x2E ;
      FUN_Req.byte(3)=  DIDHigh;
      FUN_Req.byte(4)=  DIDLow;
      FUN_Req.byte(5)=  W_array[0];
      FUN_Req.byte(6)=  W_array[1];
      FUN_Req.byte(7)=  W_array[2];
      output(FUN_Req);
      testwaitfortimeout(50); //100
   
    
      FUN_Req.dlc = 8;
      FUN_Req.byte(0)=  0x21;
      FUN_Req.byte(1)=  W_array[3];
      FUN_Req.byte(2)=  W_array[4];
      FUN_Req.byte(3)=  W_array[5];
      FUN_Req.byte(4)=  W_array[6];
      FUN_Req.byte(5)=  W_array[7];
      FUN_Req.byte(6)=  W_array[8];
      FUN_Req.byte(7)=  W_array[9];
      output(FUN_Req);
      testwaitfortimeout(50); 
     
  }
    
   if(No_of_Bytes > 0x0D)
  {
      FUN_Req.dlc = 8;
      FUN_Req.byte(0)=  0x22;
      FUN_Req.byte(1)=  W_array[10];
      FUN_Req.byte(2)=  W_array[11];
      FUN_Req.byte(3)=  W_array[12];
      FUN_Req.byte(4)=  W_array[13];
      FUN_Req.byte(5)=  W_array[14];
      FUN_Req.byte(6)=  W_array[15];
      FUN_Req.byte(7)=  W_array[16];
      output(FUN_Req);
      testwaitfortimeout(50); 
  }
  if (No_of_Bytes > 0x14)
  {
      FUN_Req.dlc = 8;
      FUN_Req.byte(0)=  0x23;
      FUN_Req.byte(1)=  W_array[17];
      FUN_Req.byte(2)=  W_array[18];
      FUN_Req.byte(3)=  W_array[19];
      FUN_Req.byte(4)=  W_array[20];
      FUN_Req.byte(5)=  W_array[21];
      FUN_Req.byte(6)=  W_array[22];
      FUN_Req.byte(7)=  W_array[23];
      output(FUN_Req);
      testwaitfortimeout(50);
  }
   if (No_of_Bytes > 0x1B)
  {
      FUN_Req.dlc = 8;
      FUN_Req.byte(0)=  0x24;
      FUN_Req.byte(1)=  W_array[24];
      FUN_Req.byte(2)=  W_array[25];
      FUN_Req.byte(3)=  W_array[26];
      FUN_Req.byte(4)=  W_array[27];
      FUN_Req.byte(5)=  W_array[28];
      FUN_Req.byte(6)=  W_array[29];
      FUN_Req.byte(7)=  W_array[30];
      output(FUN_Req);
      testwaitfortimeout(50);
  }
  if (No_of_Bytes > 0x22)
  {
      FUN_Req.dlc = 8;
      FUN_Req.byte(0)=  0x25;
      FUN_Req.byte(1)=  W_array[31];
      FUN_Req.byte(2)=  W_array[32];
      FUN_Req.byte(3)=  W_array[33];
      FUN_Req.byte(4)=  W_array[34];
      FUN_Req.byte(5)=  W_array[35];
      FUN_Req.byte(6)=  W_array[36];
      FUN_Req.byte(7)=  W_array[37];
      output(FUN_Req);
      testwaitfortimeout(50);
  }
      
      if(No_of_Bytes <= 0x07)
      DIAGNOSTIC_REQUEST("",W_array,8);
      
      if((No_of_Bytes>0x07)&& (No_of_Bytes<0x0D))
      DIAGNOSTIC_REQUEST("",W_array,16);
      
      if((No_of_Bytes>0x0D)&& (No_of_Bytes<0x14))
      DIAGNOSTIC_REQUEST("",W_array,24);
      
      if((No_of_Bytes>0x14)&& (No_of_Bytes<0x1B))
      DIAGNOSTIC_REQUEST("",W_array,32);
      
      if((No_of_Bytes>0x1B)&& (No_of_Bytes<0x22))
      DIAGNOSTIC_REQUEST("",W_array,40);
      
      if(O_Resp[0]==0x10)
     OBSERVED_DATA("",O_Resp,( O_Resp[1] + ((O_Resp[1] - 6)/7) + 3 ));
    else
     OBSERVED_DATA("",O_Resp,8);
      
      Expect1(0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
      EXPECTED_DATA ("",E_Resp,8);  
//      OBSERVED_DATA("",O_Resp,8);
      Check(E_Resp,O_Resp);
      testWaitForTimeout(2000); 
    
  }


