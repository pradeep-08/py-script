    STEP();
    Write1(0x10,0x21,0x2E,DID_H,DID_L,0x01,0x01,0x01);
    Write2(0x21,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write3(0x22,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write4(0x23,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write5(0x24,0x01,0x01,0x01,0x01,0x01,0x01,0x01);
    Write_did(DID_H,DID_L,0x21);
    testWaitForTimeout(100);
    DIAGNOSTIC_REQUEST("",Tx_buffer,40);
    testWaitForTimeout(200);
    OBSERVED_DATA("",O_Resp,8);
    Expect(0x03,0x7F,0x2E,0x31,0xCC,0xCC,0xCC,0xCC);
    EXPECTED_DATA("",E_Resp,8);
    Check(E_Resp,O_Resp,8);
    testWaitForTimeout(5000);
    clear_buffer();
  
    //////////////////////////////////////////////////////////////////
    STEP_DATA("Test Step");
    TestcaseID_DATA(TestcaseIDD,DTCStepCount++);
    ACTION("Read DID to confirm that the data values are not written");
    STEP();
    send_on_CAN(0x03,0x22,DID_H,DID_L,0x00,0x00,0x00,0x00);
    OBSERVED_DATA("",O_Resp,40);
    Expect1(0x10,0x21,0x62,DID_H,DID_L,0x00,0x00,0x00);
    Expect2(0x21,0xFF,0xFF,0x00,0x00,0x00,0x00,0x00);
    Expect3(0x22,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect4(0x23,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    Expect5(0x24,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
    EXPECTED_DATA("",E_Resp,40);
    Check(E_Resp,O_Resp,40);
    Clear_Buffer();
  return DTCStepCount;
}

