/** 
@brief EXPECTED_DATA

Function to add string and data to "expected_data" field.
String is added at the end of "expected_data" field

@param string input string
@param data input byte
@param data_lenght contains how lenght is data field
@return  result(0)
@author BZA & PLE
*/

long EXPECTED_DATA (char string[], byte data[], int data_length)
{
    long lResult;
    char strTemp[MAX_STR_LEN];
    char strByte[4];
    long lStrLen;
    word i;
    
    if(wExpected_DataLen > 0)
    {
        lStrLen = snprintf(strTemp,MAX_STR_LEN,"\n%s",string);
        strncat(strExpected_Data, strTemp, MAX_STR_LEN);  
    }
    else
    {
        lStrLen = snprintf(strExpected_Data,MAX_STR_LEN,"%s",string);
    }

    for(i=0; i < data_length; i++)
    {
        if(data[i] < 0x10)
        {
            snprintf(strByte, 4, " 0%X", data[i]);
        }
        else
        {
            snprintf(strByte, 4, " %X", data[i]);
        }
        strncat(strExpected_Data, strByte, MAX_STR_LEN);
    } 
    
    wExpected_DataLen = strlen(strExpected_Data); 

    Return lResult;
}

