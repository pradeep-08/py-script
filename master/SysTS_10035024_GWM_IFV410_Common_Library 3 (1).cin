 Void ICAN_SIGNAL_MIN_MAX_CHECK(char Signal_name[ ], float FACTOR, float OFFSET, float Min, long Max)
{
  float Signal_Value,TrueValue;
 
  Signal_Value = getSignal(Signal_name);
  
  TrueValue = (Signal_Value*FACTOR) + OFFSET;
  
  if(( TrueValue >= Min ) &&( TrueValue <= Max ))
  {
    
    Add_To_Report(PASSED);
  }
  else
  {
    Add_To_Report(FAILED);
  }
  
  
}
void Checkvalue(double v1,double v2)
{
  if(((0.98*v2)<=v1)&&((1.02*v2)>=v1))
  {
    OBSERVED("Observed Value,",(int)v1);
    EXPECTED("Expected Value,",(int)v2);
    Add_To_Report(PASSED);
    }
  else
  {
    OBSERVED("Observed Value,",(int)v1);
    EXPECTED("Expected Value,",(int)v2);
    Add_To_Report(FAILED);
}
  
}
void Checkvalue_float(double v1,double v2)
{
  
  if(((0.98*v2)<=v1)&&((1.02*v2)>=v1))
  {
    
    OBSERVED("Observed Value,",v1);
    EXPECTED("Expected Value,",v2);
    Add_To_Report(PASSED);
    }
  else
  {
    
    OBSERVED("Observed Value,",v1);
    EXPECTED("Expected Value,",v2);
    Add_To_Report(FAILED);
}
  
}


