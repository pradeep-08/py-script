IFV300_REQ_SEED()
{
  send_on_CAN (0x02,0x27,0x01,0x00,0x00,0x00,0x00,0x00);
  testWaitForTimeout(50);
  OBSERVED_DATA("",O_Resp,8);
  Expect(0x06,0x67,0x01,O_Resp[3],O_Resp[4],O_Resp[5],O_Resp[6],0x00);
  EXPECTED_DATA("",E_Resp,8);
  check(E_Resp,O_Resp,8);
  GWM_KEY_VAL = IFV300_Calculate_KEY(O_Resp[3],O_Resp[4],O_Resp[5],O_Resp[6]);
  testWaitForTimeout(100);
  
}

long IFV300_Calculate_KEY( byte seed1,byte seed2,byte seed3,byte seed4)
{
  long key_val = 0;
  long seed_val;
  int i;
  seed_val = ((seed1<<24) +(seed2<<16) +(seed3<<8) + seed4) & 0xFFFFFFFF ;
  
                if (seed_val !=0)
                                {
                                                for (i=0;i<35;i++)
                                                {
                                                if (seed_val & 0x80000000)
                                                                {
                                                                seed_val = seed_val << 1;
                                                                seed_val = seed_val ^ 0x46534641;
                                                                }
                                                                else
                                                                {
                                                                seed_val = seed_val << 1;
                                                                }
                                                }
                                                key_val = seed_val;
                                }
  
  return key_val; 
}


IFV300_SEND_KEY()
{  
  
  byte key1,key2,key3,key4;
  key1= ((GWM_KEY_VAL>>24) & 0x000000FF);
  key2= ((GWM_KEY_VAL>>16) & 0x000000FF);
  key3= ((GWM_KEY_VAL>>8) & 0x000000FF);
  key4= (GWM_KEY_VAL&0x000000FF);
  Step();
  //ACTION("Send KEY"); 
  send_on_CAN (0x06,0x27,0x02,key1,key2,key3,key4,0x00); 
  testWaitForTimeout(200);
  Expect(0x02,0x67,0x02,0x00,0x00,0x00,0x00,0x00);
  OBSERVED_DATA("",O_Resp,8);
  EXPECTED_DATA("",E_Resp,8);
  check(E_Resp,O_Resp,8);
}


void DTC_Qualifiction_time_Check(Long DTC_NUM )
{
   float T1=0xff,backup,T2= 0xFF,QulaTime=0; 
  int r;
  T1=(timeNowFloat()/100);
  
   for(r=0;r<400;r++)
  {
    
  DIAG_Req.dlc = 8; 
  DIAG_Req.byte(0)=  0x06; 
  DIAG_Req.byte(1)=  0x19; 
  DIAG_Req.byte(2)=  0x06; 
  DIAG_Req.byte(3)=  (DTC_NUM & 0xFF0000) >> 16; 
  DIAG_Req.byte(4)=  (DTC_NUM & 0x00FF00) >> 8; 
  DIAG_Req.byte(5)=  DTC_NUM & 0x0000FF ; 
  DIAG_Req.byte(6)=  0xFF; 
  output(DIAG_Req); 
  testWaitForTimeout(30);
 // OBSERVED_DATA("",O_Resp,16);    
 //   AddToReport();
    backup=(timeNowFloat()/100);
    if(((backup-T1)>=1500))
    {
      break;
    }
    if(O_Resp[7] == 0x2B) 
    {
      
      break;
    }
  }
  
  if((backup-T1)<1500)
  {
  T2=(timeNowFloat()/100);
  QulaTime = T2-T1;
   OBSERVED("qualification time is  : ",QulaTime);
    AddToReport();
  }
  else{
    OBSERVED("\n Fault Not Qualified with in 1500 msec"); 
    AddToReport(FAILED);
  }
  
}

void DTC_DeQualifiction_time_Check(Long DTC_NUM )
{
   float T1=0xff,backup,T2= 0xFF,QulaTime=0; 

  T1=(timeNowFloat()/100);
  
  while(O_Resp[7] != 0x2A) 
  {
    
  DIAG_Req.dlc = 8; 
  DIAG_Req.byte(0)=  0x06; 
  DIAG_Req.byte(1)=  0x19; 
  DIAG_Req.byte(2)=  0x06; 
  DIAG_Req.byte(3)=  (DTC_NUM & 0xFF0000) >> 16; 
  DIAG_Req.byte(4)=  (DTC_NUM & 0x00FF00) >> 8; 
  DIAG_Req.byte(5)=  DTC_NUM & 0x0000FF ; 
  DIAG_Req.byte(6)=  0xFF; 
  output(DIAG_Req); 
  testWaitForTimeout(30);
  //OBSERVED_DATA("",O_Resp,16);    
 //   AddToReport();
    backup=(timeNowFloat()/100);
    if((backup-T1)>=1500)
    {
      break;
    }
    
  }
  
  if((backup-T1)<=1500)
  {
  T2=(timeNowFloat()/100);
  QulaTime = T2-T1;
   OBSERVED("De qualification time is  : ",QulaTime);
    AddToReport();
  }
  else{
    OBSERVED("\n Fault Not DeQualified with in 1500msec"); 
    AddToReport(FAILED);
  }
  
}

