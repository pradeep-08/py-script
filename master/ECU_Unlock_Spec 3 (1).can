    /*-----------------------------ACTION: Enter Extended Session ---------------------------------------*/
    Extended_Session_Phy();
    
    /*-------------------------------Test Step 9--------------------------------------*/ 
    /*-----------------------------ACTION: Writing DID which support Security level 1 --------------------*/
    STEP();
    ACTION("Write DID F199 ");                                                    //Write DID which support Security level 1  
    send_on_CAN(0x07,0x2E,0xF1,0x99,0x20,0x25,0x09,0x24);
    testWaitForTimeout(100);
    Expect(0x03,0x7F,0x2E,0x33,0xAA,0xAA,0xAA,0xAA);
    EXPECTED_DATA("",E_Resp,0X08);
